BROWSER_DESKTOP_MAP: dict[str, str] = {
    "firefox":              "firefox",
    "org.mozilla.firefox":  "firefox",
    "microsoft-edge":       "edge",
    "com.microsoft.edge":   "edge",
    "msedge":               "edge",
    "edge":                 "edge",
    "brave":                "brave",
    "brave-browser":        "brave",
    "com.brave.browser":    "brave",
    "vivaldi":              "vivaldi",
    "com.vivaldi.vivaldi":  "vivaldi",
    "google-chrome":        "chrome",
    "com.google.chrome":    "chrome",
    "chrome":               "chrome",
    "chromium":             "chromium",
    "chromium-browser":     "chromium",
    "org.chromium.chromium":"chromium",
    "opera":                "opera",
    "com.opera.opera":      "opera",
}

_SNAP_NAMES: dict[str, str] = {
    "firefox":            "firefox",
    "edge":               "microsoft-edge",
    "brave":              "brave",
    "vivaldi":            "vivaldi",
    "chrome":             "google-chrome",
    "chromium":           "chromium",
    "opera":              "opera",
    "ungoogled-chromium": "ungoogled-chromium",
}

def is_wayland_session() -> bool:
    return bool(os.environ.get('WAYLAND_DISPLAY'))

def is_x11_session() -> bool:
    return bool(os.environ.get('DISPLAY')) and not is_wayland_session()

def get_session_type() -> str:
    if is_wayland_session():
        return "wayland"
    elif is_x11_session():
        return "x11"
    return "unknown"

def detect_wayland_compositor() -> str:
    if not is_wayland_session():
        return "unknown"
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        return "hyprland"
    if os.environ.get("SWAYSOCK"):
        return "sway"
    xdg = (os.environ.get("XDG_CURRENT_DESKTOP") or "").lower()
    ds  = (os.environ.get("DESKTOP_SESSION") or "").lower()
    combined = f"{xdg} {ds}"
    if "gnome" in combined:
        return "gnome"
    if "kde" in combined or "plasma" in combined:
        return "kde"
    if "sway" in combined:
        return "sway"
    if "hyprland" in combined:
        return "hyprland"
    if "cosmic" in combined:
        return "cosmic"
    if "wayfire" in combined:
        return "wayfire"
    if "river" in combined:
        return "river"
    if "labwc" in combined:
        return "labwc"
    try:
        procs = subprocess.run(
            ["ps", "-eo", "comm"], capture_output=True, text=True, timeout=2
        ).stdout.lower()
        for name, comp in [("gnome-shell","gnome"),("kwin_wayland","kde"),
                            ("sway","sway"),("hyprland","hyprland"),
                            ("cosmic-comp","cosmic"),("wayfire","wayfire"),
                            ("river","river"),("labwc","labwc")]:
            if name in procs:
                return comp
    except Exception:
        pass
    return "unknown"

def get_display_backend_flags(browser_key: str = "") -> str:
    session = get_session_type()
    chromium_browsers = ["edge","brave","vivaldi","chrome","chromium","opera","ungoogled-chromium"]
    if browser_key.lower() not in chromium_browsers:
        return ""
    if session == "x11":
        return "--use-gl=desktop --ignore-gpu-blocklist"
    if session == "wayland":
        compositor = detect_wayland_compositor()
        base = "--ozone-platform=wayland --enable-features=UseOzonePlatform"
        if compositor in ("kde", "gnome", "cosmic", "sway", "hyprland",
                          "river", "labwc", "wayfire"):
            return f"{base},WaylandWindowDecorations"
        return f"{base},WaylandWindowDecorations"
    return "--ozone-platform-hint=auto"

def detect_browser_installation(browser_key: str) -> dict:
    browsers_info = {
        "firefox":            {"native_cmds": ["firefox", "/usr/bin/firefox"],
                               "flatpak": "org.mozilla.firefox", "snap": "firefox", "name": "Firefox"},
        "edge":               {"native_cmds": ["microsoft-edge", "microsoft-edge-stable"],
                               "flatpak": "com.microsoft.Edge", "snap": "microsoft-edge", "name": "Microsoft Edge"},
        "brave":              {"native_cmds": ["brave-browser-stable", "brave-browser", "brave"],
                               "flatpak": "com.brave.Browser", "snap": "brave", "name": "Brave"},
        "vivaldi":            {"native_cmds": ["vivaldi", "vivaldi-stable"],
                               "flatpak": "com.vivaldi.Vivaldi", "snap": "vivaldi", "name": "Vivaldi"},
        "chrome":             {"native_cmds": ["google-chrome", "google-chrome-stable"],
                               "flatpak": "com.google.Chrome", "snap": "google-chrome", "name": "Google Chrome"},
        "chromium":           {"native_cmds": ["chromium", "chromium-browser"],
                               "flatpak": "org.chromium.Chromium", "snap": "chromium", "name": "Chromium"},
        "opera":              {"native_cmds": ["opera", "opera-stable"],
                               "flatpak": "com.opera.Opera", "snap": "opera", "name": "Opera"},
        "ungoogled-chromium": {"native_cmds": ["ungoogled-chromium"],
                               "flatpak": None, "snap": None, "name": "Ungoogled Chromium"},
    }
    if browser_key not in browsers_info:
        return {'type': 'not_found', 'cmd': '', 'display_name': browser_key}
    info = browsers_info[browser_key]
    for cmd in info["native_cmds"]:
        if shutil.which(cmd):
            return {'type': 'native', 'cmd': cmd,
                    'display_name': f"{info['name']} (Native)"}
    if info.get("flatpak"):
        try:
            result = subprocess.run(
                ["flatpak", "info", info["flatpak"]],
                capture_output=True, text=True, timeout=2)
            if result.returncode == 0:
                return {'type': 'flatpak', 'cmd': f"flatpak run {info['flatpak']}",
                        'flatpak_id': info['flatpak'],
                        'display_name': f"{info['name']} (Flatpak)"}
        except Exception:
            pass
    if info.get("snap"):
        try:
            result = subprocess.run(
                ["snap", "list", info["snap"]],
                capture_output=True, text=True, timeout=2)
            if result.returncode == 0:
                return {'type': 'snap', 'cmd': f"snap run {info['snap']}",
                        'snap_name': info['snap'],
                        'display_name': f"{info['name']} (Snap)"}
        except Exception:
            pass
    return {'type': 'not_found', 'cmd': '',
            'display_name': f"{info['name']} (Not Installed)"}

def get_default_browser() -> str:
    try:
        result = subprocess.run(
            ["xdg-settings", "get", "default-web-browser"],
            capture_output=True, text=True, timeout=2)
        if result.returncode == 0:
            desktop_file = result.stdout.strip().lower()
            browser_map = BROWSER_DESKTOP_MAP
            desktop_name = desktop_file.replace('.desktop', '')
            if desktop_name in browser_map:
                return browser_map[desktop_name]
            for key, browser_key in browser_map.items():
                if key in desktop_file:
                    return browser_key
    except Exception:
        pass
    try:
        mimeapps_paths = [
            Path.home() / '.config/mimeapps.list',
            Path.home() / '.local/share/applications/mimeapps.list',
            Path('/etc/xdg/mimeapps.list'),
        ]
        for mimeapps_path in mimeapps_paths:
            if mimeapps_path.exists():
                with open(mimeapps_path, 'r') as f:
                    content = f.read().lower()
                    for pattern, browser_key in BROWSER_DESKTOP_MAP.items():
                        if (f'text/html={pattern}' in content or
                                f'x-scheme-handler/http={pattern}' in content):
                            return browser_key
    except Exception:
        pass
    try:
        result = subprocess.run(
            ["gio", "mime", "x-scheme-handler/http"],
            capture_output=True, text=True, timeout=2)
        if result.returncode == 0:
            desktop_file = result.stdout.strip().lower()
            for key, browser_key in BROWSER_DESKTOP_MAP.items():
                if key in desktop_file:
                    return browser_key
    except Exception:
        pass
    priority_order = ['edge', 'firefox', 'chrome', 'brave', 'chromium', 'vivaldi', 'opera']
    for browser in priority_order:
        detection = detect_browser_installation(browser)
        if detection['type'] != 'not_found':
            return browser
    return 'firefox'

def scan_available_browsers() -> dict:
    browsers = {}
    for browser_key in ["firefox","edge","brave","vivaldi","chrome",
                         "chromium","opera","ungoogled-chromium"]:
        detection = detect_browser_installation(browser_key)
        if detection['type'] != 'not_found':
            browsers[browser_key] = detection
    return browsers

_PORTAL_BACKENDS: dict[str, str] = {
    "kde":       "xdg-desktop-portal-kde",
    "gnome":     "xdg-desktop-portal-gnome",
    "cosmic":    "xdg-desktop-portal-cosmic",
    "hyprland":  "xdg-desktop-portal-hyprland",
    "sway":      "xdg-desktop-portal-wlr",
    "river":     "xdg-desktop-portal-wlr",
    "labwc":     "xdg-desktop-portal-wlr",
    "wayfire":   "xdg-desktop-portal-wlr",
    "x11":       "xdg-desktop-portal-gtk",
    "unknown":   "xdg-desktop-portal-gtk",
}

def check_webhid_portal() -> dict:
    compositor = detect_wayland_compositor() if is_wayland_session() else "x11"
    portal_pkg = _PORTAL_BACKENDS.get(compositor, "xdg-desktop-portal-gtk")
    result: dict = {"ok": False, "portal": portal_pkg, "reason": "",
                    "running": False, "backend_found": False}
    if not shutil.which("xdg-desktop-portal"):
        result["reason"] = (
            "xdg-desktop-portal is not installed. "
            "WebHID/gamepad permission dialogs will not appear.")
        return result
    try:
        pgrep = subprocess.run(
            ["pgrep", "-x", "xdg-desktop-por"], capture_output=True, timeout=2)
        if pgrep.returncode != 0:
            pgrep = subprocess.run(
                ["pgrep", "-f", "xdg-desktop-portal"], capture_output=True, timeout=2)
        result["running"] = pgrep.returncode == 0
    except Exception:
        result["running"] = False
    extra_dirs = ["/usr/libexec", "/usr/lib/xdg-desktop-portal",
                  "/usr/lib", "/usr/local/libexec"]
    backend_found = bool(shutil.which(portal_pkg))
    if not backend_found:
        backend_found = any((Path(d) / portal_pkg).exists() for d in extra_dirs)
    result["backend_found"] = backend_found
    if not result["running"]:
        result["reason"] = (
            f"xdg-desktop-portal is installed but not running. "
            f"Start it with: systemctl --user start xdg-desktop-portal")
        return result
    if not backend_found:
        result["reason"] = (
            f"The portal daemon is running but the {compositor.upper()} backend "
            f"({portal_pkg}) was not found.")
        return result
    result["ok"] = True
    result["reason"] = f"Portal OK ({portal_pkg} present and daemon running)"
    return result


# ─────────────────────────────────────────────────────────────────────────────
# Utilities
# ─────────────────────────────────────────────────────────────────────────────

def slugify(text: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")

def sanitize_shell_string(value: str) -> str:
    return re.sub(r'[^a-zA-Z0-9 _.~/:?=&#%+@-]', '', value)

def get_browsers():
    return CONFIG.get("browsers", DEFAULT_CONFIG.get("browsers", {}))

def get_profile_dir(app: dict) -> Path:
    return CONFIG_DIR / "profiles" / slugify(app.get("name", "untitled"))

def profile_config_path(app: dict) -> Path:
    return get_profile_dir(app) / "profile.json"

def load_profile_config(app: dict) -> dict:
    p = profile_config_path(app)
    if p.exists():
        try:
            return json.loads(p.read_text())
        except Exception:
            return {}
    return {}

def save_profile_config(app: dict, data: dict):
    pd = get_profile_dir(app)
    pd.mkdir(parents=True, exist_ok=True)
    target = profile_config_path(app)
    tmp = target.with_suffix(".json.tmp")
    try:
        tmp.write_text(json.dumps(data, indent=2), encoding="utf-8")
        tmp.chmod(0o600)
        tmp.rename(target)
    except Exception as exc:
        _logger.error("save_profile_config failed: %s", exc)
        tmp.unlink(missing_ok=True)
        raise

def get_hostname_from_url(url: str) -> str:
    try:
        parsed = urlparse(url)
        hostname = parsed.netloc or parsed.path
        return hostname.replace('www.', '').split('/')[0].split(':')[0]
    except Exception:
        return ""

def check_for_updates(callback):
    def _check():
        try:
            import urllib.request
            import ssl
            url = "https://api.github.com/repos/bobbycomet/Appify/releases/latest"
            ctx = ssl.create_default_context()
            req = urllib.request.Request(
                url,
                headers={"Accept": "application/vnd.github+json",
                         "User-Agent": f"Appify/{CURRENT_VERSION}"})
            with urllib.request.urlopen(req, context=ctx, timeout=8) as resp:
                if resp.status != 200:
                    return
                data = json.loads(resp.read().decode())
            if data.get("prerelease") or data.get("draft"):
                return
            latest_tag = data["tag_name"].lstrip("v")
            if Version(latest_tag) > Version(CURRENT_VERSION):
                msg = f"New version available: {data['tag_name']}!\nDownload from GitHub Releases."
                GLib.idle_add(callback, msg)
        except Exception as exc:
            _logger.debug("Update check failed: %s", exc)
    threading.Thread(target=_check, daemon=True).start()

APPIFY_GITHUB_REPO = "bobbycomet/Appify"

def check_appify_latest_release() -> "dict | None":
    """Fetch the latest GitHub release info for Appify itself (separate from the
    lightweight check_for_updates() banner check — this one also grabs asset URLs
    so we can actually download and install the update)."""
    try:
        import urllib.request, ssl
        ctx = ssl.create_default_context()
        req = urllib.request.Request(
            f"https://api.github.com/repos/{APPIFY_GITHUB_REPO}/releases/latest",
            headers={"Accept": "application/vnd.github+json",
                     "User-Agent": f"Appify/{CURRENT_VERSION}"})
        with urllib.request.urlopen(req, context=ctx, timeout=10) as resp:
            if resp.status != 200:
                return None
            data = json.loads(resp.read().decode())
    except Exception as exc:
        _logger.debug("check_appify_latest_release failed: %s", exc)
        return None
    if data.get("prerelease") or data.get("draft"):
        return None
    tag = data.get("tag_name", "")
    if not tag:
        return None
    appimage_url = ""
    deb_url = ""
    for asset in data.get("assets", []):
        url = asset.get("browser_download_url", "")
        if url.lower().endswith(".appimage"):
            appimage_url = url
        elif url.lower().endswith(".deb"):
            deb_url = url
    return {
        "tag": tag,
        "version": tag.lstrip("v"),
        "appimage_url": appimage_url,
        "deb_url": deb_url,
        "html_url": data.get("html_url", f"https://github.com/{APPIFY_GITHUB_REPO}/releases"),
    }


def _detect_appify_install_type() -> "tuple[str, str]":
    """Returns (install_type, appimage_path). install_type is 'appimage', 'deb', or 'unknown'."""
    env_appimage = os.environ.get("APPIMAGE", "")
    if env_appimage and Path(env_appimage).is_file():
        return "appimage", env_appimage
    try:
        result = subprocess.run(
            ["dpkg-query", "-W", "-f=${Status}", "appify"],
            capture_output=True, text=True, timeout=5)
        if "install ok installed" in result.stdout:
            return "deb", ""
    except Exception:
        pass
    return "unknown", ""


def _run_privileged_script(script: str, timeout: int = 60) -> "tuple[bool, str]":
    try:
        proc = subprocess.run(["pkexec", "bash", "-c", script],
                               capture_output=True, text=True, timeout=timeout)
        if proc.returncode == 0:
            return True, ""
        return False, (proc.stderr or proc.stdout or f"exit code {proc.returncode}").strip()
    except Exception as exc:
        return False, str(exc)


def _appify_updater_timer_unit(schedule: str) -> str:
    return (
        "[Unit]\n"
        f"Description=Run Appify Updater ({schedule})\n\n"
        "[Timer]\n"
        f"OnCalendar={schedule}\n"
        "Persistent=true\n\n"
        "[Install]\n"
        "WantedBy=timers.target\n"
    )


APPIFY_UPDATER_SERVICE_UNIT = \
'[Unit]\nDescription=Appify Updater Service\nAfter=network-online.target\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/appify-updater.sh\n'

APPIFY_UPDATER_SCRIPT = \
'#!/bin/bash\nset -euo pipefail\n\n# =====================================\n# Appify Self-Updater\n# =====================================\n# Updates Appify itself from GitHub releases. Supports both AppImage and\n# .deb installs. Run as root (via the appify-updater.service/.timer pair).\n\nGITHUB_REPO="bobbycomet/Appify"\nCONFIG_FILE="/etc/appify-updater.conf"\nLOG_FILE="/var/log/appify-updater.log"\nCACHE_DIR="/var/cache/appify-updater"\nCACHE_FILE="$CACHE_DIR/last_check"\n\nmkdir -p "$CACHE_DIR" 2>/dev/null || true\n\n# Utility function for logging (stdout for the journal + a persistent logfile)\nlog() {\n    local line\n    line="[$(date \'+%Y-%m-%d %H:%M:%S\')] $*"\n    echo "$line"\n    echo "$line" >> "$LOG_FILE" 2>/dev/null || true\n}\n\n# Notification function (only if notify-send exists)\nnotify_user() {\n    local message="$1"\n    if command -v notify-send &>/dev/null; then\n        for user_runtime in /run/user/*; do\n            user_id=$(basename "$user_runtime")\n            if [ -S "$user_runtime/bus" ]; then\n                sudo -u "#$user_id" DBUS_SESSION_BUS_ADDRESS="unix:path=$user_runtime/bus" \\\n                    notify-send "Appify Updater" "$message" || true\n            fi\n        done\n    else\n        log "ℹ️ Notifications skipped (notify-send not installed)."\n    fi\n}\n\n# Ensure required commands exist\nfor cmd in curl dpkg-query dpkg; do\n    if ! command -v "$cmd" &>/dev/null; then\n        echo "Error: Required command \'$cmd\' not found."\n        exit 1\n    fi\ndone\n\n# =====================================\n# Load / bootstrap config\n# =====================================\n# CONFIG_FILE format:\n#   INSTALL_TYPE=appimage|deb\n#   APPIMAGE_PATH=/full/path/to/Appify.AppImage   (only used if INSTALL_TYPE=appimage)\n#   DEB_PACKAGE_NAME=appify                        (only used if INSTALL_TYPE=deb)\n\nINSTALL_TYPE=""\nAPPIMAGE_PATH=""\nDEB_PACKAGE_NAME="appify"\n\nif [ -f "$CONFIG_FILE" ]; then\n    # shellcheck disable=SC1090\n    source "$CONFIG_FILE"\nfi\n\nbootstrap_config() {\n    # Try to figure out how Appify is installed if no config exists yet.\n    if dpkg-query -W -f=\'${Status}\' "$DEB_PACKAGE_NAME" 2>/dev/null | grep -q "install ok installed"; then\n        INSTALL_TYPE="deb"\n        log "Detected deb install of Appify (package: $DEB_PACKAGE_NAME)."\n    else\n        # Look for a recorded AppImage path in known desktop launcher files.\n        local desktop_files=(\n            "/usr/share/applications/appify.desktop"\n            "/usr/local/share/applications/appify.desktop"\n        )\n        for df in "${desktop_files[@]}"; do\n            if [ -f "$df" ]; then\n                local exec_path\n                exec_path=$(grep -m1 \'^Exec=\' "$df" | sed -E \'s/^Exec=//; s/ .*//\')\n                if [ -n "$exec_path" ] && [ -f "$exec_path" ]; then\n                    INSTALL_TYPE="appimage"\n                    APPIMAGE_PATH="$exec_path"\n                    log "Detected AppImage install of Appify at: $APPIMAGE_PATH"\n                    break\n                fi\n            fi\n        done\n    fi\n\n    if [ -z "$INSTALL_TYPE" ]; then\n        log "⚠️ Could not detect how Appify is installed. Skipping this run."\n        log "   Create $CONFIG_FILE manually with INSTALL_TYPE=appimage (+ APPIMAGE_PATH=...) or INSTALL_TYPE=deb."\n        exit 0\n    fi\n\n    {\n        echo "INSTALL_TYPE=$INSTALL_TYPE"\n        echo "APPIMAGE_PATH=$APPIMAGE_PATH"\n        echo "DEB_PACKAGE_NAME=$DEB_PACKAGE_NAME"\n    } > "$CONFIG_FILE"\n    chmod 644 "$CONFIG_FILE"\n}\n\nif [ -z "$INSTALL_TYPE" ]; then\n    bootstrap_config\nfi\n\nif [ "$INSTALL_TYPE" = "appimage" ] && { [ -z "$APPIMAGE_PATH" ] || [ ! -f "$APPIMAGE_PATH" ]; }; then\n    log "❌ INSTALL_TYPE=appimage but APPIMAGE_PATH (\'$APPIMAGE_PATH\') doesn\'t exist. Fix $CONFIG_FILE."\n    exit 1\nfi\n\n# =====================================\n# Determine currently installed version\n# =====================================\nif [ "$INSTALL_TYPE" = "deb" ]; then\n    CURRENT_VERSION=$(dpkg-query -W -f=\'${Version}\' "$DEB_PACKAGE_NAME" 2>/dev/null || true)\nelse\n    CURRENT_VERSION=$("$APPIMAGE_PATH" --print-version 2>/dev/null || true)\nfi\n\nif [ -z "$CURRENT_VERSION" ]; then\n    log "⚠️ Could not determine the currently installed Appify version. Continuing anyway."\n    CURRENT_VERSION="0"\nelse\n    log "Current installed Appify version: $CURRENT_VERSION"\nfi\n\n# =====================================\n# Fetch latest release info from GitHub\n# =====================================\nlog "Checking for the latest Appify release..."\nRELEASE_JSON=$(curl -fsSL -H "Accept: application/vnd.github+json" \\\n    "https://api.github.com/repos/${GITHUB_REPO}/releases/latest") || {\n    log "❌ Failed to reach the GitHub releases API."\n    exit 1\n}\n\nLATEST_TAG=$(echo "$RELEASE_JSON" | grep -m1 \'"tag_name"\' | sed -E \'s/.*"tag_name":[[:space:]]*"([^"]+)".*/\\1/\')\nif [ -z "$LATEST_TAG" ]; then\n    log "❌ Failed to parse the latest release tag."\n    exit 1\nfi\nLATEST_VERSION="${LATEST_TAG#v}"\n\necho "$(date -Iseconds) latest=$LATEST_VERSION" > "$CACHE_FILE" 2>/dev/null || true\n\nlog "Latest Appify version available: $LATEST_VERSION"\n\nif dpkg --compare-versions "$CURRENT_VERSION" ge "$LATEST_VERSION" 2>/dev/null; then\n    log "✨ Appify is already up to date."\n    exit 0\nfi\n\n# =====================================\n# Download + install the update\n# =====================================\nif [ "$INSTALL_TYPE" = "appimage" ]; then\n    ASSET_URL=$(echo "$RELEASE_JSON" \\\n        | grep -o \'"browser_download_url":[[:space:]]*"[^"]*\\.AppImage"\' \\\n        | sed -E \'s/.*"(https[^"]+)"/\\1/\' | head -n1)\n    if [ -z "$ASSET_URL" ]; then\n        log "❌ No .AppImage asset found in the latest release."\n        exit 1\n    fi\n\n    TMP_FILE=$(mktemp /tmp/appify.XXXXXX.AppImage)\n    log "⬇️  Downloading Appify v$LATEST_VERSION (AppImage)..."\n    if ! curl -fsSL -o "$TMP_FILE" "$ASSET_URL"; then\n        log "❌ Failed to download the new AppImage."\n        rm -f "$TMP_FILE"\n        exit 1\n    fi\n    log "SHA-256: $(sha256sum "$TMP_FILE" | cut -d\' \' -f1)"\n\n    chmod +x "$TMP_FILE"\n    # Overwrite in place, at the exact path the user originally chose, so\n    # desktop launchers/symlinks that point at APPIMAGE_PATH keep working.\n    # mv within the same directory is atomic and effectively removes the old file.\n    if ! mv -f "$TMP_FILE" "$APPIMAGE_PATH"; then\n        log "❌ Failed to install the new AppImage to $APPIMAGE_PATH."\n        rm -f "$TMP_FILE"\n        exit 1\n    fi\n    chmod +x "$APPIMAGE_PATH"\n\n    log "✅ Appify has been updated to version $LATEST_VERSION successfully! ($APPIMAGE_PATH)"\n    notify_user "Appify has been updated to version $LATEST_VERSION ✅"\n\nelse\n    DEB_URL=$(echo "$RELEASE_JSON" \\\n        | grep -o \'"browser_download_url":[[:space:]]*"[^"]*\\.deb"\' \\\n        | sed -E \'s/.*"(https[^"]+)"/\\1/\' | head -n1)\n    if [ -z "$DEB_URL" ]; then\n        log "❌ No .deb asset found in the latest release."\n        exit 1\n    fi\n\n    DEB_FILE=$(mktemp /tmp/appify.XXXXXX.deb)\n    log "⬇️  Downloading Appify v$LATEST_VERSION (.deb)..."\n    if ! curl -fsSL -o "$DEB_FILE" "$DEB_URL"; then\n        log "❌ Failed to download the new .deb package."\n        rm -f "$DEB_FILE"\n        exit 1\n    fi\n    log "SHA-256: $(sha256sum "$DEB_FILE" | cut -d\' \' -f1)"\n\n    log "📦 Installing Appify v$LATEST_VERSION..."\n    if ! apt-get install -y "$DEB_FILE"; then\n        log "❌ Installation failed."\n        rm -f "$DEB_FILE"\n        exit 1\n    fi\n    rm -f "$DEB_FILE"\n\n    log "✅ Appify has been updated to version $LATEST_VERSION successfully!"\n    notify_user "Appify has been updated to version $LATEST_VERSION ✅"\nfi\n'


def is_appify_updater_installed() -> bool:
    return Path("/etc/systemd/system/appify-updater.timer").exists()


def get_appify_updater_schedule() -> "str | None":
    timer_path = Path("/etc/systemd/system/appify-updater.timer")
    if not timer_path.exists():
        return None
    try:
        for line in timer_path.read_text().splitlines():
            line = line.strip()
            if line.startswith("OnCalendar="):
                return line.split("=", 1)[1].strip()
    except Exception:
        pass
    return None


def enable_appify_updater(schedule: str, status_callback=None) -> bool:
    """Install the appify-updater.sh/.service/.timer/.conf files and enable the
    timer, in a single pkexec prompt."""
    install_type, appimage_path = _detect_appify_install_type()
    if install_type == "unknown":
        if status_callback:
            status_callback("Could not detect a deb or AppImage install of Appify — "
                             "automatic updates unavailable.")
        return False

    tmp_dir = Path(tempfile.mkdtemp(prefix="appify-updater-"))
    try:
        sh_path      = tmp_dir / "appify-updater.sh"
        service_path = tmp_dir / "appify-updater.service"
        timer_path   = tmp_dir / "appify-updater.timer"
        conf_path    = tmp_dir / "appify-updater.conf"

        sh_path.write_text(APPIFY_UPDATER_SCRIPT)
        service_path.write_text(APPIFY_UPDATER_SERVICE_UNIT)
        timer_path.write_text(_appify_updater_timer_unit(schedule))
        conf_lines = [f"INSTALL_TYPE={install_type}"]
        if install_type == "appimage":
            conf_lines.append(f"APPIMAGE_PATH={appimage_path}")
        conf_lines.append("DEB_PACKAGE_NAME=appify")
        conf_path.write_text("\n".join(conf_lines) + "\n")

        script = (
            "set -e\n"
            f"cp {shlex.quote(str(sh_path))} /usr/local/bin/appify-updater.sh\n"
            "chmod 755 /usr/local/bin/appify-updater.sh\n"
            f"cp {shlex.quote(str(service_path))} /etc/systemd/system/appify-updater.service\n"
            f"cp {shlex.quote(str(timer_path))} /etc/systemd/system/appify-updater.timer\n"
            f"cp {shlex.quote(str(conf_path))} /etc/appify-updater.conf\n"
            "chmod 644 /etc/systemd/system/appify-updater.service "
            "/etc/systemd/system/appify-updater.timer /etc/appify-updater.conf\n"
            "systemctl daemon-reload\n"
            "systemctl enable --now appify-updater.timer\n"
        )
        ok, err = _run_privileged_script(script)
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)

    if status_callback:
        status_callback("Automatic update checks enabled." if ok
                         else f"Failed to enable automatic updates: {err}")
    return ok


def set_appify_updater_schedule(schedule: str, status_callback=None) -> bool:
    tmp_dir = Path(tempfile.mkdtemp(prefix="appify-updater-"))
    try:
        timer_path = tmp_dir / "appify-updater.timer"
        timer_path.write_text(_appify_updater_timer_unit(schedule))
        script = (
            "set -e\n"
            f"cp {shlex.quote(str(timer_path))} /etc/systemd/system/appify-updater.timer\n"
            "chmod 644 /etc/systemd/system/appify-updater.timer\n"
            "systemctl daemon-reload\n"
            "systemctl restart appify-updater.timer\n"
        )
        ok, err = _run_privileged_script(script)
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)
    if status_callback:
        status_callback(f"Update check schedule set to: {schedule}" if ok
                         else f"Failed to update schedule: {err}")
    return ok


def disable_appify_updater(status_callback=None) -> bool:
    ok, err = _run_privileged_script("systemctl disable --now appify-updater.timer")
    if status_callback:
        status_callback("Automatic update checks disabled." if ok
                         else f"Failed to disable automatic updates: {err}")
    return ok


def install_appify_update(release: dict, status_callback=None) -> bool:
    """Download and install the latest Appify release, matching the current
    install type (AppImage overwritten in place, or apt-get install for .deb)."""
    install_type, appimage_path = _detect_appify_install_type()
    if install_type == "unknown":
        if status_callback:
            status_callback("Could not detect how Appify is installed — cannot self-update.")
        return False

    if install_type == "appimage":
        if not release.get("appimage_url"):
            if status_callback:
                status_callback("No AppImage asset found in the latest release.")
            return False
        tmp_file = Path(tempfile.mktemp(suffix=".AppImage"))
        if status_callback:
            status_callback(f"Downloading Appify {release['version']} (AppImage)…")
        if not download_file(release["appimage_url"], tmp_file, timeout=60):
            if status_callback:
                status_callback("Download failed.")
            return False
        try:
            tmp_file.chmod(0o755)
            target = Path(appimage_path)
            target_dir = target.parent
            if os.access(target_dir, os.W_OK) and (not target.exists() or os.access(target, os.W_OK)):
                shutil.move(str(tmp_file), str(target))
                target.chmod(0o755)
            else:
                script = (
                    "set -e\n"
                    f"mv -f {shlex.quote(str(tmp_file))} {shlex.quote(str(target))}\n"
                    f"chmod 755 {shlex.quote(str(target))}\n"
                )
                ok, err = _run_privileged_script(script)
                if not ok:
                    if status_callback:
                        status_callback(f"Install failed: {err}")
                    return False
            if status_callback:
                status_callback(
                    f"Appify updated to {release['version']}! Restart Appify to use the new version.")
            return True
        finally:
            tmp_file.unlink(missing_ok=True)
    else:
        if not release.get("deb_url"):
            if status_callback:
                status_callback("No .deb asset found in the latest release.")
            return False
        tmp_file = Path(tempfile.mktemp(suffix=".deb"))
        if status_callback:
            status_callback(f"Downloading Appify {release['version']} (.deb)…")
        if not download_file(release["deb_url"], tmp_file, timeout=60):
            if status_callback:
                status_callback("Download failed.")
            return False
        try:
            if status_callback:
                status_callback(f"Installing Appify {release['version']}…")
            script = f"apt-get install -y {shlex.quote(str(tmp_file))}"
            ok, err = _run_privileged_script(script, timeout=180)
            if not ok:
                if status_callback:
                    status_callback(f"Install failed: {err}")
                return False
            if status_callback:
                status_callback(
                    f"Appify updated to {release['version']}! Restart Appify to use the new version.")
            return True
        finally:
            tmp_file.unlink(missing_ok=True)


def get_profile_size(app: dict) -> str:
    profile_dir = get_profile_dir(app)
    if not profile_dir.exists():
        return "—"
    try:
        total = sum(
            f.stat().st_size for f in profile_dir.rglob("*") if f.is_file())
        if total < 1024:
            return f"{total} B"
        elif total < 1024 ** 2:
            return f"{total / 1024:.1f} KB"
        elif total < 1024 ** 3:
            return f"{total / 1024 ** 2:.1f} MB"
        else:
            return f"{total / 1024 ** 3:.2f} GB"
    except Exception:
        return "—"

def get_app_key(app) -> str:
    """Return the app's store id (slug) used to look up extension presets."""
    return app.get("id", "")


def get_available_presets(app, browser_key: str = "") -> list:
    """Return extension entries from the store for this app + browser combo,
    excluding ones already installed in the app's profile."""
    app_id = get_app_key(app)
    if not app_id:
        return []
    if not browser_key:
        profile_cfg = load_profile_config(app)
        browser_key = (profile_cfg.get("browser") or
                       app.get("browser") or
                       CONFIG.get("browser", "firefox"))
    compat        = _browser_compat(browser_key)
    all_exts      = _STORE_EXT_PRESETS.get(app_id, [])
    installed_set = {ext["name"] for ext in load_installed_extensions(app)}
    return [
        {"name": e["name"], "web_url": e["store_url"], "browser": e["browser"]}
        for e in all_exts
        if e.get("browser") == compat and e["name"] not in installed_set
    ]

def load_installed_extensions(app):
    if not app:
        return []
    return load_profile_config(app).get("extensions", [])

def save_installed_extensions(app, exts):
    """Persist extension list, deduplicating by name."""
    seen: set = set()
    deduped: list = []
    for ext in exts:
        name = ext.get("name", "")
        if name and name not in seen:
            seen.add(name)
            deduped.append(ext)
    profile_cfg = load_profile_config(app)
    profile_cfg["extensions"] = deduped
    save_profile_config(app, profile_cfg)

def get_icon_path(app: dict) -> Path:
    return ICON_DIR / f"{slugify(app['name'])}.png"

def get_desktop_file_path(app: dict) -> Path:
    return DESKTOP_DIR / f"pwa-{slugify(app['name'])}-manager.desktop"

def download_file(url: str, path: Path, timeout: int = 10) -> bool:
    try:
        subprocess.run(
            ["curl", "-fLs", "--proto", "https,http",
             "--max-filesize", "2097152",
             "--connect-timeout", "5",
             "--max-time", str(timeout),
             "--no-sessionid", "-o", str(path), url],
            check=True, timeout=timeout + 5)
        return True
    except Exception:
        return False

def validate_url(url: str) -> bool:
    try:
        parsed = urlparse(url)
        return (parsed.scheme in ("http", "https")
                and bool(parsed.netloc)
                and len(url) <= 2048)
    except Exception:
        return False

def download_icon(app: dict, status_callback=None):
    hostname = get_hostname_from_url(app['url'])
    if not hostname:
        if status_callback:
            status_callback("Failed to parse hostname")
        return
    icon_path = get_icon_path(app)
    ICON_DIR.mkdir(parents=True, exist_ok=True)

    def _is_image(p: Path) -> bool:
        if not p.exists() or p.stat().st_size < 8:
            return False
        try:
            header = p.read_bytes()[:8]
            return (header[:4] == b'\x89PNG'
                    or header[:2] in (b'\xff\xd8',)
                    or header[:3] == b'GIF'
                    or header[:4] == b'\x00\x00\x01\x00'
                    or header[:2] == b'BM'
                    or header[:4] == b'RIFF')
        except Exception:
            return False

    sources = [
        f"https://icon.horse/icon/{hostname}?size=large",
        f"https://www.google.com/s2/favicons?domain={hostname}&sz=256",
    ]
    try:
        parsed = urlparse(app['url'])
        if parsed.scheme and parsed.netloc:
            sources.append(f"{parsed.scheme}://{parsed.netloc}/favicon.ico")
    except Exception:
        pass

    for src in sources:
        if download_file(src, icon_path, timeout=8):
            if _is_image(icon_path):
                label = "Icon" if src == sources[0] else "Fallback icon"
                if status_callback:
                    status_callback(f"{label}: {hostname}")
                try:
                    icon_theme_root = ICON_DIR.parents[1]
                    subprocess.run(
                        ["gtk-update-icon-cache", "-f", "-t", str(icon_theme_root)],
                        check=False, capture_output=True, timeout=5)
                except Exception:
                    pass
                return
            else:
                icon_path.unlink(missing_ok=True)
    if status_callback:
        status_callback("Icon download failed")

def set_custom_icon(app: dict, source_path: Path, status_callback=None) -> bool:
    """Copy/convert a user-chosen image (PNG/JPEG/GIF/BMP/ICO/SVG) into the app's
    icon slot. Marks the app as using a custom icon so future installs/updates
    don't silently overwrite it with an auto-downloaded favicon."""
    icon_path = get_icon_path(app)
    ICON_DIR.mkdir(parents=True, exist_ok=True)
    try:
        pix = QPixmap(str(source_path))
        if pix.isNull():
            if status_callback:
                status_callback(f"Could not read image: {source_path.name}")
            return False
        if pix.width() > 512 or pix.height() > 512:
            pix = pix.scaled(512, 512, Qt.AspectRatioMode.KeepAspectRatio,
                              Qt.TransformationMode.SmoothTransformation)
        if not pix.save(str(icon_path), "PNG"):
            if status_callback:
                status_callback("Failed to save icon")
            return False
        try:
            icon_theme_root = ICON_DIR.parents[1]
            subprocess.run(
                ["gtk-update-icon-cache", "-f", "-t", str(icon_theme_root)],
                check=False, capture_output=True, timeout=5)
        except Exception:
            pass
        profile_cfg = load_profile_config(app)
        profile_cfg["custom_icon"] = True
        save_profile_config(app, profile_cfg)
        if status_callback:
            status_callback(f"Custom icon set: {source_path.name}")
        return True
    except Exception as exc:
        _logger.warning("set_custom_icon failed: %s", exc)
        if status_callback:
            status_callback(f"Custom icon failed: {exc}")
        return False

def reset_icon_to_auto(app: dict, status_callback=None):
    """Clear the custom-icon flag and re-download the favicon-based icon."""
    profile_cfg = load_profile_config(app)
    profile_cfg.pop("custom_icon", None)
    save_profile_config(app, profile_cfg)
    get_icon_path(app).unlink(missing_ok=True)
    download_icon(app, status_callback)


# ─────────────────────────────────────────────────────────────────────────────
# Config Paths
# ─────────────────────────────────────────────────────────────────────────────

CONFIG_DIR  = Path(os.path.expanduser("~/.appify"))
CONFIG_FILE = CONFIG_DIR / "config.json"
ICON_DIR    = Path(os.path.expanduser("~/.local/share/icons/hicolor/512x512/apps/"))
DESKTOP_DIR = Path(os.path.expanduser("~/.local/share/applications/"))
LOG_FILE    = CONFIG_DIR / "launch.log"

_OLD_CONFIG_DIR = Path(os.path.expanduser("~/.pwa_manager"))
_MIGRATION_NEEDED = _OLD_CONFIG_DIR.exists() and not CONFIG_DIR.exists()

if not CONFIG_DIR.exists() and _OLD_CONFIG_DIR.exists():
    CONFIG_DIR  = _OLD_CONFIG_DIR
    CONFIG_FILE = CONFIG_DIR / "config.json"
    LOG_FILE    = CONFIG_DIR / "launch.log"

def save_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    tmp_path = CONFIG_FILE.with_suffix(".json.tmp")
    try:
        payload = json.dumps(CONFIG, indent=2)
        tmp_path.write_text(payload, encoding="utf-8")
        tmp_path.chmod(0o600)
        tmp_path.rename(CONFIG_FILE)
    except Exception as exc:
        _logger.error("save_config failed: %s", exc)
        tmp_path.unlink(missing_ok=True)
        raise


# ─────────────────────────────────────────────────────────────────────────────
# Preset / Category / Default App data
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Store catalog — fetched from GitHub, cached locally
# ─────────────────────────────────────────────────────────────────────────────

STORE_URL        = "https://raw.githubusercontent.com/bobbycomet/Appify/main/store.json"
STORE_CACHE_FILE = CONFIG_DIR / "store_cache.json"
STORE_CACHE_TTL  = 86400  # seconds — refresh at most once per day

# In-memory store data populated by _load_store_catalog()
# {app_id: [{"name":…, "browser":"chromium"|"firefox", "store_url":…}, …]}
_STORE_EXT_PRESETS: "dict[str, list]" = {}
_STORE_APPS: "list[dict]" = []


def _browser_compat(browser_key: str) -> str:
    """Return 'firefox' or 'chromium' for any browser key."""
    return "firefox" if browser_key.lower() == "firefox" else "chromium"


def get_effective_browser(app: dict, user_selected: str) -> str:
    """Return the browser that should actually be used for this app.
    browser_override is a hard constraint (cloud gaming etc.).
    recommended_browser is advisory only; user_selected wins if no hard override."""
    override = (app.get("browser_override") or "").strip().lower()
    if override and override in CONFIG.get("available_browsers", {}):
        return override
    if override:
        _logger.warning("browser_override '%s' for '%s' is not installed — using user selection",
                        override, app.get("name", "?"))
    return user_selected


def _validate_store(data: dict) -> "list[str]":
    """Validate a parsed store dict against its own validation block.
    Returns a list of error strings; empty = valid."""
    errors: list = []
    val           = data.get("validation", {})
    req_app       = val.get("required_app_fields",       ["id", "name", "url", "category"])
    req_ext       = val.get("required_extension_fields",  ["name", "store_url", "browser"])
    allowed_cats  = set(val.get("allowed_categories",    []))
    allowed_brows = set(val.get("allowed_browser_values", ["chromium", "firefox"]))

    seen_ids: set = set()
    for app in data.get("apps", []):
        loc = f"app '{app.get('name','?')}'"
        for f in req_app:
            if f not in app:
                errors.append(f"{loc}: missing required field '{f}'")
        url = app.get("url", "")
        if not url.startswith("https://"):
            errors.append(f"{loc}: URL not HTTPS — {url!r}")
        aid = app.get("id", "")
        if aid in seen_ids:
            errors.append(f"Duplicate app id: {aid!r}")
        seen_ids.add(aid)
        cat = app.get("category", "")
        if allowed_cats and cat not in allowed_cats:
            errors.append(f"{loc}: unknown category {cat!r}")

    for preset in data.get("extension_presets", []):
        for ext in preset.get("extensions", []):
            loc = f"extension '{ext.get('name','?')}' (app '{preset.get('app_id','?')}')"
            for f in req_ext:
                if f not in ext:
                    errors.append(f"{loc}: missing field '{f}'")
            if not ext.get("store_url", "").startswith("https://"):
                errors.append(f"{loc}: store_url not HTTPS")
            if allowed_brows and ext.get("browser", "") not in allowed_brows:
                errors.append(f"{loc}: unknown browser value {ext.get('browser','')!r}")
    return errors


def _fetch_store_from_network() -> "dict | None":
    """Download and validate store.json from GitHub. Returns parsed dict or None."""
    try:
        import urllib.request, ssl
        ctx = ssl.create_default_context()
        req = urllib.request.Request(
            STORE_URL,
            headers={"User-Agent": f"Appify/{CURRENT_VERSION}", "Accept": "application/json"})
        with urllib.request.urlopen(req, context=ctx, timeout=10) as resp:
            if resp.status != 200:
                _logger.warning("Store fetch HTTP %d", resp.status)
                return None
            raw = resp.read().decode("utf-8")
    except Exception as exc:
        _logger.warning("Store fetch failed: %s", exc)
        return None

    try:
        data = json.loads(raw)
    except Exception as exc:
        _logger.warning("Store JSON parse error: %s", exc)
        return None

    schema_ver = data.get("schema_version")
    if schema_ver != 1:
        _logger.warning("Unsupported store schema_version: %s", schema_ver)
        return None

    errs = _validate_store(data)
    if errs:
        _logger.warning("Store validation errors (%d); first: %s", len(errs), errs[0])
        return None

    # Cache to disk
    try:
        import time
        data["_cached_at"] = time.time()
        STORE_CACHE_FILE.parent.mkdir(parents=True, exist_ok=True)
        tmp = STORE_CACHE_FILE.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(data, indent=2), encoding="utf-8")
        tmp.chmod(0o600)
        tmp.rename(STORE_CACHE_FILE)
        _logger.info("Store catalog cached: %d apps, %d ext presets",
                     len(data.get("apps", [])),
                     len(data.get("extension_presets", [])))
    except Exception as exc:
        _logger.warning("Store cache write failed: %s", exc)

    return data


def _load_store_from_cache() -> "dict | None":
    """Load cached store.json if it exists and is within TTL."""
    if not STORE_CACHE_FILE.exists():
        return None
    try:
        import time
        data = json.loads(STORE_CACHE_FILE.read_text(encoding="utf-8"))
        age  = time.time() - data.get("_cached_at", 0)
        if age > STORE_CACHE_TTL:
            return None          # stale — caller should re-fetch
        return data
    except Exception:
        return None


def _apply_store_catalog(data: dict):
    """Merge store apps and extension presets into live CONFIG and in-memory
    globals.  Existing user-installed apps are preserved; store apps are added
    or updated.  Custom apps added by the user (not in the store) are kept."""
    global _STORE_EXT_PRESETS, _STORE_APPS

    # ── extension presets: index by app_id ──────────────────────────────────
    _STORE_EXT_PRESETS = {}
    for preset in data.get("extension_presets", []):
        _STORE_EXT_PRESETS[preset["app_id"]] = preset.get("extensions", [])

    # ── apps: merge into CONFIG["apps"] ─────────────────────────────────────
    store_apps = data.get("apps", [])
    _STORE_APPS = store_apps

    # Collect categories from store for the UI
    all_cats: list = data.get("validation", {}).get("allowed_categories", [])
    if all_cats:
        global CATEGORIES
        CATEGORIES = all_cats

    existing_ids = set(CONFIG["apps"].keys())
    added = updated = 0
    for app in store_apps:
        app_id = app.get("id", "")
        if not app_id:
            continue
        slug = app_id                           # store ids are already slugs
        if slug not in existing_ids:
            app_copy = app.copy()
            app_copy.setdefault("browser", CONFIG.get("browser", "firefox"))
            CONFIG["apps"][slug] = app_copy
            added += 1
        else:
            # Update non-user fields (category, description, url) but keep
            # user overrides (browser, kiosk, gamepad) untouched.
            existing = CONFIG["apps"][slug]
            for field in ("url", "category", "description", "kiosk",
                          "gamepad", "browser_override", "recommended_browser"):
                if field in app:
                    existing[field] = app[field]
            existing["id"] = slug
            updated += 1

    _logger.info("Store applied: %d added, %d updated, %d total apps",
                 added, updated, len(CONFIG["apps"]))


def _load_store_catalog(status_callback=None):
    """Load from cache first; if stale or missing, fetch from network.
    Applies the result to CONFIG.  Safe to call from background thread."""
    cached = _load_store_from_cache()
    if cached:
        _apply_store_catalog(cached)
        if status_callback:
            status_callback(f"Catalog loaded from cache ({len(cached.get('apps',[]))} apps)")
        # Refresh in the background if the cache is getting old
        import time
        age = time.time() - cached.get("_cached_at", 0)
        if age > STORE_CACHE_TTL * 0.75:
            threading.Thread(target=_background_store_refresh,
                             args=(status_callback,), daemon=True).start()
        return

    # No cache — must fetch
    if status_callback:
        status_callback("Fetching app catalog from GitHub…")
    data = _fetch_store_from_network()
    if data:
        _apply_store_catalog(data)
        if status_callback:
            status_callback(f"Catalog updated: {len(data.get('apps',[]))} apps, "
                            f"{len(data.get('extension_presets',[]))} extension presets")
    else:
        if status_callback:
            status_callback("Catalog fetch failed — working offline")
        _logger.warning("Store fetch failed and no cache available")


def _background_store_refresh(status_callback=None):
    """Fetch a fresh store copy in a background thread and apply it."""
    data = _fetch_store_from_network()
    if data:
        _apply_store_catalog(data)
        if status_callback:
            GLib.idle_add(status_callback,
                          f"Catalog refreshed: {len(data.get('apps',[]))} apps")


