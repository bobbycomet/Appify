    def _build_options(self):
        grp = QGroupBox("Options")
        grid = QGridLayout(grp)
        grid.setSpacing(10)

        grid.addWidget(QLabel("URL:"), 0, 0)
        self.url_entry = QLineEdit()
        grid.addWidget(self.url_entry, 0, 1, 1, 3)

        grid.addWidget(QLabel("Browser:"), 1, 0)
        self.browser_combo = QComboBox()
        self.refresh_browser_combo()
        self.browser_combo.currentIndexChanged.connect(self.on_browser_changed)
        grid.addWidget(self.browser_combo, 1, 1, 1, 3)

        icon_label = QLabel("Icon:")
        icon_label.setToolTip(
            "Use a custom PNG/JPEG/GIF/BMP/ICO/SVG icon instead of the "
            "auto-downloaded favicon. Applied immediately, before Install.")
        grid.addWidget(icon_label, 2, 0)
        self.icon_thumb_label = QLabel()
        self.icon_thumb_label.setFixedSize(32, 32)
        self.icon_thumb_label.setScaledContents(True)
        self.icon_thumb_label.setToolTip(icon_label.toolTip())
        grid.addWidget(self.icon_thumb_label, 2, 1)
        icon_browse_btn = QPushButton(tr("Browse…"))
        icon_browse_btn.setToolTip("Choose a custom icon image for this app.")
        icon_browse_btn.clicked.connect(self._on_browse_icon)
        grid.addWidget(icon_browse_btn, 2, 2)
        icon_reset_btn = QPushButton(tr("Reset to Auto"))
        icon_reset_btn.setToolTip("Discard the custom icon and re-download the site's favicon.")
        icon_reset_btn.clicked.connect(self._on_reset_icon)
        grid.addWidget(icon_reset_btn, 2, 3)

        self._content_layout.addWidget(grp)

    def _refresh_icon_thumbnail(self, app: "dict | None"):
        if not app:
            self.icon_thumb_label.clear()
            return
        icon_path = get_icon_path(app)
        if icon_path.exists():
            pix = QPixmap(str(icon_path))
            if not pix.isNull():
                self.icon_thumb_label.setPixmap(pix)
                return
        self.icon_thumb_label.clear()

    def _on_browse_icon(self):
        app = self.get_selected_app()
        if not app:
            _q_msg(self, tr("No App Selected"), tr("Select an app first."), [(tr("OK"), "default")])
            return
        path, _filter = QFileDialog.getOpenFileName(
            self, tr("Select Icon"), str(Path.home()),
            tr("Images (*.png *.jpg *.jpeg *.gif *.bmp *.ico *.svg);;All files (*)"))
        if not path:
            return
        ok = set_custom_icon(app, Path(path), self.status_push)
        if ok:
            self._refresh_icon_thumbnail(app)
            self.populate_app_combo()

    def _on_reset_icon(self):
        app = self.get_selected_app()
        if not app:
            _q_msg(self, tr("No App Selected"), tr("Select an app first."), [(tr("OK"), "default")])
            return
        self.status_push(tr("Resetting icon…"))
        def _worker():
            reset_icon_to_auto(app, lambda msg: GLib.idle_add(self.status_push, msg))
            GLib.idle_add(self._refresh_icon_thumbnail, app)
            GLib.idle_add(self.populate_app_combo)
        threading.Thread(target=_worker, daemon=True).start()

