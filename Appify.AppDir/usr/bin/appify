# ─────────────────────────────────────────────────────────────────────────────
# PyQt6 UI Helpers
# ─────────────────────────────────────────────────────────────────────────────

def _q_msg(parent, title: str, body: str,
           buttons: "list[tuple[str,str]]",
           default_btn: str = "") -> str:
    """
    Shows a modal dialog with the given buttons.
    buttons: list of (label, role) where role is 'cancel'|'suggested'|'destructive'|'default'
    Returns the label of the clicked button, or '' if closed.
    """
    dlg = QDialog(parent)
    dlg.setWindowTitle(title)
    dlg.setMinimumWidth(420)
    layout = QVBoxLayout(dlg)
    layout.setSpacing(12)
    layout.setContentsMargins(20, 20, 20, 16)

    title_lbl = QLabel(f"<b>{title}</b>")
    title_lbl.setWordWrap(True)
    title_lbl.setProperty("class", "title")
    layout.addWidget(title_lbl)

    body_lbl = QLabel(body)
    body_lbl.setWordWrap(True)
    body_lbl.setTextFormat(Qt.TextFormat.PlainText)
    layout.addWidget(body_lbl)
    layout.addSpacing(4)

    btn_layout = QHBoxLayout()
    btn_layout.setSpacing(8)
    btn_layout.addStretch()
    result = [""]

    for label, role in buttons:
        btn = QPushButton(label)
        if role == 'suggested':
            btn.setProperty("class", "suggested")
            btn.style().unpolish(btn)
            btn.style().polish(btn)
        elif role == 'destructive':
            btn.setProperty("class", "destructive")
            btn.style().unpolish(btn)
            btn.style().polish(btn)
        def _make_handler(lbl):
            def handler():
                result[0] = lbl
                dlg.accept()
            return handler
        btn.clicked.connect(_make_handler(label))
        btn_layout.addWidget(btn)

    layout.addLayout(btn_layout)
    dlg.exec()
    return result[0]


class _CollapsibleSection(QWidget):
    """A collapsible section like GTK Expander."""
    def __init__(self, title: str, parent=None):
        super().__init__(parent)
        outer = QVBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.setSpacing(0)

        self._toggle_btn = QPushButton(f"▶  {title}")
        self._toggle_btn.setCheckable(True)
        self._toggle_btn.setChecked(False)
        self._toggle_btn.setStyleSheet(
            "QPushButton { text-align: left; background-color: #1e2d3d; "
            "border: 1px solid #2a475e; border-radius: 3px; padding: 6px 10px; "
            "color: #8bc4e0; font-weight: bold; }"
            "QPushButton:hover { background-color: #2a475e; }"
            "QPushButton:checked { background-color: #2a475e; border-color: #417a9b; }")
        self._toggle_btn.toggled.connect(self._on_toggled)
        outer.addWidget(self._toggle_btn)

        self._content = QWidget()
        self._content.setVisible(False)
        outer.addWidget(self._content)
        self._title = title

    def _on_toggled(self, checked: bool):
        self._content.setVisible(checked)
        arrow = "▼" if checked else "▶"
        self._toggle_btn.setText(f"{arrow}  {self._title}")

    def set_content_layout(self, layout):
        self._content.setLayout(layout)


class _UpdateBanner(QFrame):
    """Steam-styled update notification banner."""
    button_clicked = pyqtSignal()

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setFrameShape(QFrame.Shape.StyledPanel)
        self.setStyleSheet(
            "QFrame { background-color: #1a3a5c; border: 1px solid #1a9fff; "
            "border-radius: 3px; }")
        self.setVisible(False)

        layout = QHBoxLayout(self)
        layout.setContentsMargins(12, 8, 12, 8)
        self._label = QLabel("")
        self._label.setProperty("class", "banner-label")
        layout.addWidget(self._label, 1)

        btn = QPushButton("View Releases")
        btn.setProperty("class", "suggested")
        btn.setMaximumWidth(130)
        btn.clicked.connect(self.button_clicked)
        layout.addWidget(btn)

    def set_title(self, text: str):
        self._label.setText(text)

    def set_revealed(self, revealed: bool):
        self.setVisible(revealed)


