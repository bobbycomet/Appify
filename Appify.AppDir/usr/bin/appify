class PWAManagerWindow(QMainWindow):
    # Signals for thread-safe UI updates
    _status_sig    = pyqtSignal(str)
    _prof_size_sig = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self.sorted_apps_list: list = []
        self._status_timer: "QTimer | None" = None
        self._user_browser_override: bool = False  # True when user manually picks a browser

        # Session info for title
        compositor_val = CONFIG.get('wayland_compositor', 'n/a')
        session_display = (CONFIG.get('session_type') or 'unknown').upper()
        if is_wayland_session() and compositor_val not in ("n/a", "unknown"):
            session_display += f"/{compositor_val.title()}"
        session_info = f" • {session_display}" if CONFIG.get('session_type') else ""
        self.setWindowTitle(f"Appify {CURRENT_VERSION}{session_info}")
        self.setMinimumSize(900, 700)
        self.resize(1000, 920)

        # Connect thread-safe signals
        self._status_sig.connect(self._do_status_push)
        self._prof_size_sig.connect(self._on_profile_size_ready)

        self._build_menu_bar()
        self._build_central()
        self._build_status_bar()
        self._post_init()

    # ── Menu bar ─────────────────────────────────────────────────────────────

    def _build_menu_bar(self):
        mb = self.menuBar()

        # Dark mode toggle in the left side of the toolbar
        toolbar = QToolBar("Main", self)
        toolbar.setMovable(False)
        toolbar.setFloatable(False)
        toolbar.setIconSize(QSize(16, 16))
        self.addToolBar(Qt.ToolBarArea.TopToolBarArea, toolbar)

        self._dark_mode_btn = QToolButton()
        self._dark_mode_btn.setText("🌙  Dark Mode")
        self._dark_mode_btn.setCheckable(True)
        self._dark_mode_btn.setChecked(CONFIG.get("dark_mode", True))
        self._dark_mode_btn.toggled.connect(self.on_mode_toggled)
        toolbar.addWidget(self._dark_mode_btn)

        # Hamburger menu
        app_menu = mb.addMenu("☰  Menu")
        _actions = [
            ("About Appify",            self.show_about_dialog),
            ("Rescan Browsers",         self.on_rescan_browsers),
            ("Refresh Catalog",         self.on_refresh_catalog),
            ("Restore Default Apps",    self.on_restore_defaults),
            ("Backup Manager",          self.on_open_backup_manager),
            ("Backup All Installed Apps", self.on_backup_all),
            ("Install All in Category…", self.on_install_all_in_category),
            ("Regenerate All Wrappers", self.on_regenerate_wrappers),
            ("Migrate to .appify…",     self.on_migrate_dir),
            ("Export All Data…",        self.on_export_data),
            ("Import All Data…",        self.on_import_data),
            ("Update Settings…",        self.on_open_update_settings),
        ]
        for label, handler in _actions:
            act = QAction(label, self)
            act.triggered.connect(handler)
            app_menu.addAction(act)

    # ── Central widget ────────────────────────────────────────────────────────

    def _build_central(self):
        outer = QWidget()
        outer_layout = QVBoxLayout(outer)
        outer_layout.setContentsMargins(0, 0, 0, 0)
        outer_layout.setSpacing(0)

        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)

        content = QWidget()
        content.setObjectName("content")
        content.setStyleSheet("#content { background-color: #1b2838; }")
        self._content_layout = QVBoxLayout(content)
        self._content_layout.setContentsMargins(12, 12, 12, 12)
        self._content_layout.setSpacing(10)

        # Build sections
        self._build_sys_info()
        self._build_search()
        self._build_app_selection()
        self._build_category_browser()
        self._build_options()
        self._build_advanced_options()
        self._build_extensions()
        self._build_action_buttons()

        # Update banner
        self._update_banner = _UpdateBanner()
        self._update_banner.button_clicked.connect(
            lambda: subprocess.Popen(["xdg-open", "https://github.com/bobbycomet/Appify/releases"]))
        self._content_layout.addWidget(self._update_banner)

        self._content_layout.addStretch()

        scroll.setWidget(content)
        outer_layout.addWidget(scroll)
        self.setCentralWidget(outer)

    def _build_sys_info(self):
        grp = QGroupBox("System")
        row = QHBoxLayout(grp)
        row.setSpacing(18)

        compositor_val = CONFIG.get('wayland_compositor', 'n/a')
        session_text = (CONFIG.get('session_type') or 'unknown').upper()
        if is_wayland_session() and compositor_val not in ("n/a", "unknown"):
            session_text += f" / {compositor_val.title()}"

        portal_status = check_webhid_portal()
        portal_ok_str = "✓" if portal_status["ok"] else "✗"

        for text, tooltip in [
            (f"<b>Display:</b> {session_text}", ""),
            (f"<b>Browsers Found:</b> {len(CONFIG.get('available_browsers', {}))}", ""),
            (f"<b>Default:</b> {CONFIG.get('browser','unknown').title()}", ""),
            (f"<b>WebHID Portal:</b> {portal_ok_str} {portal_status['portal']}",
             portal_status['reason']),
        ]:
            lbl = QLabel(text)
            lbl.setTextFormat(Qt.TextFormat.RichText)
            if tooltip:
                lbl.setToolTip(tooltip)
            row.addWidget(lbl)
        row.addStretch()
        self._content_layout.addWidget(grp)

    def _build_search(self):
        grp = QGroupBox("Search Apps")
        layout = QVBoxLayout(grp)
        self.search_entry = QLineEdit()
        self.search_entry.setPlaceholderText(tr("Search apps…"))
        self.search_entry.textChanged.connect(self.on_search_changed)
        layout.addWidget(self.search_entry)

        sort_row = QHBoxLayout()
        sort_row.addWidget(QLabel("Sort:"))
        self.sort_combo = QComboBox()
        self.sort_combo.addItems([
            tr("Name"), tr("Category"), tr("Recently Used"), tr("Installed First")])
        saved_sort = CONFIG.get("sort_mode", "Name")
        idx = self.sort_combo.findText(saved_sort)
        self.sort_combo.setCurrentIndex(idx if idx >= 0 else 0)
        self.sort_combo.currentTextChanged.connect(self.on_sort_changed)
        sort_row.addWidget(self.sort_combo, 1)
        layout.addLayout(sort_row)

        self._content_layout.addWidget(grp)

    def on_sort_changed(self, mode: str):
        CONFIG["sort_mode"] = mode
        save_config()
        self.populate_app_combo(self.search_entry.text().strip())
        if self.sorted_apps_list:
            self.app_combo.setCurrentIndex(0)
            self._on_app_selected_impl(0)

