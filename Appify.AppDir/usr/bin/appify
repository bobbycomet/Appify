# ─── Load config ──────────────────────────────────────────────────────────────
CONFIG_DIR.mkdir(parents=True, exist_ok=True)
if CONFIG_FILE.exists():
    try:
        CONFIG = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
    except Exception as _cfg_err:
        _logger.warning("Config load failed (%s) — using defaults", _cfg_err)
        CONFIG = DEFAULT_CONFIG.copy()
else:
    CONFIG = DEFAULT_CONFIG.copy()
    try:
        CONFIG_FILE.write_text(json.dumps(CONFIG, indent=2), encoding="utf-8")
        CONFIG_FILE.chmod(0o600)
    except Exception:
        pass

CONFIG["session_type"] = get_session_type()
CONFIG["available_browsers"] = scan_available_browsers()
CONFIG["browser"] = get_default_browser()

_cfg_ver = CONFIG.get("config_version", 1)
if _cfg_ver < 2:
    apps_collection = CONFIG.get("apps", [])
    if not isinstance(apps_collection, dict):
        CONFIG["apps"] = {
            slugify(app["name"]): app
            for app in apps_collection
            if isinstance(app, dict) and "name" in app}
    CONFIG["config_version"] = CONFIG_VERSION
elif not isinstance(CONFIG.get("apps"), dict):
    apps_collection = CONFIG.get("apps", [])
    CONFIG["apps"] = {
        slugify(app["name"]): app
        for app in apps_collection
        if isinstance(app, dict) and "name" in app}

# Store catalog is loaded at startup via _load_store_catalog() (called from
# PWAManagerWindow._post_init in a background thread).

CONFIG.setdefault("browsers", {})

# Self-healing migration: older Appify versions (or a manual config edit)
# could leave a Chromium-only `--user-data-dir` flag in Firefox's saved
# launch args. Firefox silently ignores that flag and falls back to its own
# default profile, so every per-app Firefox setting (homepage, prefs,
# userChrome.css/userContent.css) never took effect even though it looked
# "installed" and "launched fine". Detect and correct it here so nobody has
# to fix this by hand — see the "5mind" support thread that first surfaced it.
_WRAPPER_REGEN_NEEDED = False
_stale_firefox_args = CONFIG["browsers"].get("firefox", {}).get("args", "")
if "--user-data-dir" in _stale_firefox_args:
    CONFIG["browsers"].setdefault("firefox", {})
    CONFIG["browsers"]["firefox"]["args"] = DEFAULT_CONFIG["browsers"]["firefox"]["args"]
    _WRAPPER_REGEN_NEEDED = True
    _logger.warning(
        "Migrated stale Firefox launch args (--user-data-dir -> --profile); "
        "wrappers will be regenerated on startup")

for browser_key, default_data in DEFAULT_CONFIG["browsers"].items():
    if browser_key not in CONFIG["browsers"]:
        CONFIG["browsers"][browser_key] = default_data
    else:
        for key, value in default_data.items():
            CONFIG["browsers"][browser_key].setdefault(key, value)

if _WRAPPER_REGEN_NEEDED:
    save_config()

CONFIG.setdefault("dark_mode", True)
CONFIG["wayland_compositor"] = detect_wayland_compositor() if is_wayland_session() else "n/a"

_logger.info("Session: %s", CONFIG['session_type'])
if is_wayland_session():
    _logger.info("Compositor: %s", CONFIG['wayland_compositor'])
_logger.info("Default browser: %s", CONFIG['browser'])
_logger.info("Available browsers: %s", ', '.join(CONFIG['available_browsers'].keys()))

save_config()


