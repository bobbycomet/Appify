    # ── Rescan / Restore ──────────────────────────────────────────────────────

    def on_rescan_browsers(self, *_args):
        CONFIG["available_browsers"] = scan_available_browsers()
        CONFIG["browser"] = get_default_browser()
        save_config()
        self.refresh_browser_combo()
        self.status_push(tr("Rescan complete: %(count)d browser(s) found") % {
            "count": len(CONFIG['available_browsers'])})

    def on_restore_defaults(self, *_args):
        """Re-apply the store catalog so any deleted apps come back."""
        resp = _q_msg(self, "Restore Apps from Catalog",
            "This will re-fetch the online catalog and restore any apps that "
            "have been removed.\n\nInstalled app profiles and settings are not affected.",
            [("Cancel", "cancel"), ("Restore", "suggested")])
        if resp != "Restore":
            return
        self.on_refresh_catalog()

    # ── App combo / fields ────────────────────────────────────────────────────

    def get_selected_app(self) -> "dict | None":
        idx = self.app_combo.currentIndex()
        if 0 <= idx < len(self.sorted_apps_list):
            return self.sorted_apps_list[idx]
        return None

    def populate_app_combo(self, search_term: str = ""):
        all_apps = CONFIG["apps"].values()
        if search_term:
            lo = search_term.lower()
            filtered = [a for a in all_apps if lo in a["name"].lower()]
        else:
            filtered = list(all_apps)

        installed: set[str] = set(list_installed_apps())
        sort_mode = getattr(self, "sort_combo", None)
        sort_mode = sort_mode.currentText() if sort_mode else CONFIG.get("sort_mode", "Name")

        if sort_mode == tr("Category"):
            self.sorted_apps_list = sorted(
                filtered, key=lambda x: ((x.get("category") or "").lower(), x["name"].lower()))
        elif sort_mode == tr("Recently Used"):
            def _last_used(a):
                return load_profile_config(a).get("last_launched", 0)
            self.sorted_apps_list = sorted(
                filtered, key=lambda x: (-_last_used(x), x["name"].lower()))
        elif sort_mode == tr("Installed First"):
            self.sorted_apps_list = sorted(
                filtered, key=lambda x: (slugify(x["name"]) not in installed, x["name"].lower()))
        else:
            self.sorted_apps_list = sorted(filtered, key=lambda x: x["name"].lower())

        self.app_combo.blockSignals(True)
        self.app_combo.clear()
        for app in self.sorted_apps_list:
            slug = slugify(app["name"])
            text = f"✓ {app['name']}" if slug in installed else app["name"]
            self.app_combo.addItem(text)
        self.app_combo.blockSignals(False)

    def on_search_changed(self, text: str):
        self.populate_app_combo(text.strip())
        if self.sorted_apps_list:
            self.app_combo.setCurrentIndex(0)
            self._on_app_selected_impl(0)
        else:
            self.update_button_states()
            self.kiosk_check.setChecked(False)
            self.gamepad_check.setChecked(False)
            self.url_entry.setText("")
            self.populate_extensions(None)
            self.profile_size_label.setText("—")

    def on_app_selected(self, idx: int):
        self._on_app_selected_impl(idx)

    def _on_app_selected_impl(self, idx: int):
        if idx < 0 or idx >= len(self.sorted_apps_list):
            self._update_profile_size_label(None)
            return
        app = self.sorted_apps_list[idx]
        self.populate_app_fields(app)
        self.populate_extensions(app)
        self.update_button_states()
        self._update_profile_size_label(app)

    def populate_app_fields(self, app: dict):
        self.url_entry.setText(app.get("url", ""))
        self.kiosk_check.setChecked(app.get("kiosk", False))
        self.gamepad_check.setChecked(app.get("gamepad", False))
        self._refresh_icon_thumbnail(app)

        profile_cfg = load_profile_config(app)
        browser_key = (profile_cfg.get("browser") or app.get("browser") or
                       CONFIG.get("browser", "firefox")).lower()

        chromium_based = browser_key in [
            "edge","brave","vivaldi","chrome","chromium","opera","ungoogled-chromium"]
        self.gamepad_check.setEnabled(chromium_based)
        if not chromium_based:
            self.gamepad_check.setChecked(False)

        self.nice_spin.setValue(profile_cfg.get("nice",   CONFIG.get("nice",   0)))
        self.ionice_spin.setValue(profile_cfg.get("ionice", CONFIG.get("ionice", 2)))

        self.userchrome_edit.blockSignals(True)
        self.usercontent_edit.blockSignals(True)
        self.userchrome_edit.setPlainText(profile_cfg.get("userChrome", ""))
        self.usercontent_edit.setPlainText(profile_cfg.get("userContent", ""))
        self.userchrome_edit.blockSignals(False)
        self.usercontent_edit.blockSignals(False)

        available_keys = list(CONFIG.get("available_browsers", {}).keys())
        hard_override  = (app.get("browser_override") or "").strip().lower()
        soft_recommend = (app.get("recommended_browser") or "").strip().lower()

        if hard_override:
            display_key = hard_override if hard_override in available_keys else browser_key
            self.browser_combo.setEnabled(False)
            self.browser_combo.setToolTip(
                "Browser locked to " + hard_override.title() +
                " — required by this app. Edit browser_override in the catalog to change.")
        else:
            self.browser_combo.setEnabled(True)
            self.browser_combo.setToolTip("")
            display_key = (soft_recommend
                           if soft_recommend and not self._user_browser_override
                              and soft_recommend in available_keys
                           else browser_key)

        if not self._user_browser_override or hard_override:
            try:
                idx = available_keys.index(display_key)
                self.browser_combo.blockSignals(True)
                self.browser_combo.setCurrentIndex(idx)
                self.browser_combo.blockSignals(False)
            except ValueError:
                self.browser_combo.blockSignals(True)
                self.browser_combo.setCurrentIndex(0)
                self.browser_combo.blockSignals(False)

    def refresh_browser_combo(self):
        self.browser_combo.blockSignals(True)
        self.browser_combo.clear()
        available = CONFIG.get("available_browsers", {})
        for key, info in available.items():
            self.browser_combo.addItem(info['display_name'])
        self.browser_combo.blockSignals(False)

    def _get_current_browser_key(self) -> str:
        """Returns the effective browser for the current app.
        Applies get_effective_browser() so browser_override is honoured."""
        available_keys = list(CONFIG.get("available_browsers", {}).keys())
        idx = self.browser_combo.currentIndex()
        combo_browser = (available_keys[idx]
                         if 0 <= idx < len(available_keys)
                         else CONFIG.get("browser", "firefox"))
        app = self.get_selected_app()
        if app:
            return get_effective_browser(app, combo_browser)
        return combo_browser

    def _on_gamepad_toggled(self, checked: bool):
        if not checked:
            return
        portal = check_webhid_portal()
        if portal["ok"]:
            self.status_push(f"WebHID: portal OK ({portal['portal']})")
            return
        _q_msg(self, "WebHID Portal Not Ready",
            f"{portal['reason']}\n\n"
            "You can still install with WebHID enabled — the browser flags "
            "will be set — but device-permission dialogs may not appear and "
            "gamepad access could be silently denied by the sandbox.",
            [("OK, understood", "default")])
        self.status_push(f"WebHID warning: {portal['portal']} not ready")

    def on_browser_changed(self, idx: int):
        app = self.get_selected_app()
        if app and app.get("browser_override"):
            return  # hard-locked — ignore spurious signal
        self._user_browser_override = True  # user explicitly picked a browser
        available_keys = list(CONFIG.get("available_browsers", {}).keys())
        if 0 <= idx < len(available_keys):
            browser_key = available_keys[idx]
            chromium_based = browser_key in [
                "edge","brave","vivaldi","chrome","chromium","opera","ungoogled-chromium"]
            self.gamepad_check.setEnabled(chromium_based)
            if not chromium_based:
                self.gamepad_check.setChecked(False)
            self.status_push(f"Browser changed to: {browser_key.title()} — click Install to apply")

    # ── Extensions ────────────────────────────────────────────────────────────

    def populate_extensions(self, app: "dict | None"):
        # Clear all rows
        while self.ext_list_layout.count():
            child = self.ext_list_layout.takeAt(0)
            if child.widget():
                child.widget().deleteLater()

        if not app:
            lbl = QLabel("Select an app to view extensions.")
            lbl.setProperty("class", "caption")
            lbl.setContentsMargins(8, 6, 8, 6)
            self.ext_list_layout.addWidget(lbl)
            return

        installed_exts = load_installed_extensions(app)
        if not installed_exts:
            lbl = QLabel("No extensions installed.")
            lbl.setProperty("class", "caption")
            lbl.setContentsMargins(8, 6, 8, 6)
            self.ext_list_layout.addWidget(lbl)
        else:
            for ext in installed_exts:
                row = QWidget()
                row_layout = QHBoxLayout(row)
                row_layout.setContentsMargins(8, 4, 8, 4)
                lbl = QLabel(ext.get("name", "Unknown"))
                row_layout.addWidget(lbl, 1)
                rm_btn = QPushButton("Remove")
                rm_btn.setProperty("class", "destructive")
                rm_btn.setMaximumWidth(80)
                rm_btn.setMinimumHeight(24)
                rm_btn.style().unpolish(rm_btn)
                rm_btn.style().polish(rm_btn)
                rm_btn.clicked.connect(lambda _, e=ext, a=app: self.on_remove_ext(a, e))
                row_layout.addWidget(rm_btn)
                self.ext_list_layout.addWidget(row)

        self.ext_list_layout.addStretch()

    # ── Button state management ───────────────────────────────────────────────

    def update_button_states(self):
        idx = self.app_combo.currentIndex()
        valid = 0 <= idx < len(self.sorted_apps_list)

        for btn in [self.install_btn, self.uninstall_btn, self.clone_btn,
                    self.remove_btn, self.backup_btn, self.install_preset_btn,
                    self.open_store_btn, self.add_custom_ext_btn, self.launch_btn]:
            btn.setEnabled(valid)

        if valid:
            app = self.sorted_apps_list[idx]
            slug = slugify(app["name"])
            installed: bool = slug in set(list_installed_apps())
            self.install_btn.setEnabled(True)
            self.install_btn.setText(tr("Update Settings") if installed else tr("Install"))
            self.install_btn.setToolTip(
                tr("Re-applies Advanced Options (userChrome.css/userContent.css, Kiosk, "
                   "GPU, WebHID, Nice/I-O priority, browser) to the installed app.")
                if installed else "")
            self.uninstall_btn.setEnabled(installed)
            self.backup_btn.setEnabled(installed)
            self.launch_btn.setEnabled(installed)

    # ── Action handlers ───────────────────────────────────────────────────────

    def on_launch(self):
        app = self.get_selected_app()
        if not app:
            return
        slug = slugify(app["name"])
        launcher = CONFIG_DIR / "scripts" / f"pwa-launch-{slug}.sh"
        if launcher.exists() and os.access(str(launcher), os.X_OK):
            # Scrub stale Firefox profile locks before handing off to wrapper
            profile_cfg_launch = load_profile_config(app)
            if (profile_cfg_launch.get("browser") or "").lower() == "firefox":
                _pd = get_profile_dir(app)
                (_pd / "lock").unlink(missing_ok=True)
                (_pd / ".parentlock").unlink(missing_ok=True)
            profile_cfg_launch["last_launched"] = datetime.datetime.now().timestamp()
            save_profile_config(app, profile_cfg_launch)
            subprocess.Popen([str(launcher)], start_new_session=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            self.status_push(f"▶ Launched {app['name']}")
        else:
            self.status_push(f"{app['name']} is not installed — install it first")

    def on_install(self):
        app = self.get_selected_app()
        if not app:
            return
        self._perform_install(app)

    def on_install_custom(self):
        dlg = QDialog(self)
        dlg.setWindowTitle(tr("Install Custom PWA"))
        dlg.setMinimumWidth(440)
        layout = QVBoxLayout(dlg)
        layout.setSpacing(10)
        layout.setContentsMargins(16, 16, 16, 16)

        layout.addWidget(QLabel(tr("URL (https://…)")))
        url_input = QLineEdit()
        url_input.setPlaceholderText("https://example.com")
        layout.addWidget(url_input)

        layout.addWidget(QLabel(tr("App Name")))
        name_input = QLineEdit()
        name_input.setPlaceholderText(tr("My App"))
        layout.addWidget(name_input)

        layout.addWidget(QLabel(tr("Category (optional)")))
        cat_combo = QComboBox()
        cat_combo.addItem(tr("None"))
        for cat in CATEGORIES:
            cat_combo.addItem(cat)
        layout.addWidget(cat_combo)

        btn_box = QHBoxLayout()
        btn_box.addStretch()
        cancel_btn = QPushButton(tr("Cancel"))
        cancel_btn.clicked.connect(dlg.reject)
        install_btn = QPushButton(tr("Install"))
        install_btn.setProperty("class", "suggested")
        install_btn.style().unpolish(install_btn)
        install_btn.style().polish(install_btn)
        install_btn.setEnabled(False)
        install_btn.clicked.connect(dlg.accept)
        btn_box.addWidget(cancel_btn)
        btn_box.addWidget(install_btn)
        layout.addLayout(btn_box)

        def _validate(*_):
            url_ok  = validate_url(url_input.text().strip())
            name_ok = bool(name_input.text().strip())
            install_btn.setEnabled(url_ok and name_ok)

        def _infer_name(*_):
            raw = url_input.text().strip()
            if validate_url(raw) and not name_input.text().strip():
                try:
                    inferred = urlparse(raw).netloc.replace("www.", "").split(".")[0].capitalize()
                    if inferred:
                        name_input.setText(inferred)
                except Exception:
                    pass
            _validate()

        url_input.textChanged.connect(_infer_name)
        name_input.textChanged.connect(_validate)

        if dlg.exec() != QDialog.DialogCode.Accepted:
            return

        url  = url_input.text().strip()
        name = name_input.text().strip()
        if url and name and validate_url(url):
            cat_idx = cat_combo.currentIndex()
            selected_category = ("" if cat_idx == 0
                                 else CATEGORIES[cat_idx - 1])
            browser_key_selected = self._get_current_browser_key()
            app = {
                "name":     name,
                "url":      url,
                "kiosk":    self.kiosk_check.isChecked(),
                "gamepad":  self.gamepad_check.isChecked() if self.gamepad_check.isEnabled() else False,
                "browser":  browser_key_selected,
                "category": selected_category,
            }
            app_slug = slugify(name)
            CONFIG["apps"][app_slug] = app
            save_config()
            self.populate_app_combo()
            new_index = next((i for i, a in enumerate(self.sorted_apps_list) if a["name"] == name), 0)
            self.app_combo.setCurrentIndex(new_index)
            self._perform_install(app)

    def _perform_install(self, app: dict):
        kiosk   = self.kiosk_check.isChecked()
        gamepad = self.gamepad_check.isChecked() if self.gamepad_check.isEnabled() else False
        browser_key = self._get_current_browser_key()
        gpu = self.gpu_check.isChecked()
        CONFIG["gpu"]    = gpu
        CONFIG["kiosk"]  = kiosk
        CONFIG["nice"]   = int(self.nice_spin.value())
        CONFIG["ionice"] = int(self.ionice_spin.value())

        app = app.copy()
        app["kiosk"]   = kiosk
        app["gamepad"] = gamepad
        app["browser"] = browser_key
        app_slug = slugify(app["name"])
        CONFIG["apps"][app_slug] = app
        save_config()

        profile_cfg = load_profile_config(app)
        profile_cfg["browser"] = browser_key
        profile_cfg["gamepad"] = gamepad
        profile_cfg["nice"]    = int(self.nice_spin.value())
        profile_cfg["ionice"]  = int(self.ionice_spin.value())
        profile_cfg["userChrome"]  = self.userchrome_edit.toPlainText()
        profile_cfg["userContent"] = self.usercontent_edit.toPlainText()
        # Clean up any leftover keys from the old, pre-3.0 CSS feature
        profile_cfg.pop("userchrome_css_source", None)
        profile_cfg.pop("usercontent_css_source", None)
        save_profile_config(app, profile_cfg)

        install_app(app, browser_key, kiosk,
                    int(self.nice_spin.value()), int(self.ionice_spin.value()),
                    gpu, self.status_push)
        self._user_browser_override = False  # reset so next app selection shows its own browser
        self.populate_app_combo()
        target_name = app.get("name", "")
        new_idx = next(
            (i for i, a in enumerate(self.sorted_apps_list) if a.get("name") == target_name), 0)
        self.app_combo.setCurrentIndex(new_idx)
        self.update_button_states()
        self._update_profile_size_label(app)
        cat_idx = self.cat_combo.currentIndex()
        if 0 <= cat_idx < len(CATEGORIES):
            self._populate_category_list(CATEGORIES[cat_idx])

    def on_uninstall(self):
        idx = self.app_combo.currentIndex()
        if idx < 0 or idx >= len(self.sorted_apps_list):
            return
        app = self.sorted_apps_list[idx]
        uninstall_app(app["name"])
        self.status_push(f"Uninstalled {app['name']}")
        self.populate_app_combo()
        if self.sorted_apps_list:
            new_idx = min(idx, len(self.sorted_apps_list) - 1)
            self.app_combo.setCurrentIndex(new_idx)
            self.populate_app_fields(self.sorted_apps_list[new_idx])
        self.update_button_states()
        self._update_profile_size_label(app)
        cat_idx = self.cat_combo.currentIndex()
        if 0 <= cat_idx < len(CATEGORIES):
            self._populate_category_list(CATEGORIES[cat_idx])

    def on_refresh(self):
        current_search = self.search_entry.text().strip()
        self.populate_app_combo(current_search)
        self.update_button_states()
        self.status_push(tr("Refreshed"))

    def on_remove_app(self):
        idx = self.app_combo.currentIndex()
        if idx < 0 or idx >= len(self.sorted_apps_list):
            return
        app = self.sorted_apps_list[idx]
        app_name = app["name"]
        app_slug = slugify(app_name)

        resp = _q_msg(self,
            tr("Remove %(name)s?") % {"name": app_name},
            tr("Remove entry. Optionally delete profile."),
            [(tr("Cancel"), "cancel"), (tr("Keep Profile"), "default"),
             (tr("Delete Profile"), "destructive")])
        if resp == tr("Cancel") or resp == "":
            return

        removed = CONFIG["apps"].pop(app_slug, None)
        if removed:
            remove_app_files(removed)

        if resp == tr("Delete Profile"):
            pd = get_profile_dir(app)
            try:
                shutil.rmtree(pd)
                self.status_push(tr("Removed + profile deleted"))
            except Exception as e:
                self.status_push(tr("Profile delete failed: %(error)s") % {"error": e})
        else:
            self.status_push(tr("Removed (profile kept)"))

        save_config()
        self.populate_app_combo(self.search_entry.text().strip())
        self.update_button_states()
        cat_idx = self.cat_combo.currentIndex()
        if 0 <= cat_idx < len(CATEGORIES):
            self._populate_category_list(CATEGORIES[cat_idx])

    def on_remove_ext(self, app: dict, ext: dict):
        exts = load_installed_extensions(app)
        if ext in exts:
            exts.remove(ext)
            save_installed_extensions(app, exts)
        self.populate_extensions(app)

    def on_install_presets(self):
        app = self.get_selected_app()
        if not app:
            return
        available = get_available_presets(app)
        if not available:
            _q_msg(self, "No Presets Available",
                   f"All available presets for {app['name']} are already installed.",
                   [("OK", "default")])
            return
        resp = _q_msg(self,
            f"Install Extension Presets for {app['name']}?",
            f"This will open your browser to install {len(available)} extension(s).",
            [("Cancel", "cancel"), ("Install", "suggested")])
        if resp != "Install":
            return
        browser_key = self._get_current_browser_key()
        available   = get_available_presets(app, browser_key)
        profile_dir = get_profile_dir(app)
        launched    = launch_extension_manager(browser_key, available, profile_dir)
        if launched:
            installed_exts = load_installed_extensions(app)
            installed_exts.extend(available)
            save_installed_extensions(app, installed_exts)
            self.populate_extensions(app)
            self.status_push(tr("Launched browser for extension installation"))
        else:
            self.status_push(tr("Failed to launch browser for extensions — check logs"))

    def on_open_store(self):
        app = self.get_selected_app()
        if not app:
            return
        browser_key = self._get_current_browser_key()
        browser_cfg = get_browsers().get(browser_key, {})
        store_url = browser_cfg.get("store_url", "https://chromewebstore.google.com/")
        if not validate_url(store_url):
            self.status_push(tr("Invalid store URL"))
            return
        profile_dir = get_profile_dir(app)
        _open_url_in_pwa_browser(browser_key, profile_dir, store_url, app)
        self.status_push(f"Opened {browser_key.title()} extension store")

    def on_add_custom_ext(self):
        app = self.get_selected_app()
        if not app:
            return
        dlg = QDialog(self)
        dlg.setWindowTitle("Add Custom Extension")
        dlg.setMinimumWidth(400)
        layout = QVBoxLayout(dlg)
        layout.setSpacing(8)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.addWidget(QLabel("Extension Name"))
        name_entry = QLineEdit()
        layout.addWidget(name_entry)
        layout.addWidget(QLabel("Extension URL"))
        url_entry = QLineEdit()
        layout.addWidget(url_entry)
        btn_row = QHBoxLayout()
        btn_row.addStretch()
        cancel_b = QPushButton("Cancel")
        cancel_b.clicked.connect(dlg.reject)
        add_b = QPushButton("Add")
        add_b.setProperty("class", "suggested")
        add_b.style().unpolish(add_b)
        add_b.style().polish(add_b)
        add_b.clicked.connect(dlg.accept)
        btn_row.addWidget(cancel_b)
        btn_row.addWidget(add_b)
        layout.addLayout(btn_row)

        if dlg.exec() != QDialog.DialogCode.Accepted:
            return

        name = name_entry.text().strip()
        url  = url_entry.text().strip()
        if not (name and url):
            return

        _ALLOWED_EXT_HOSTS = {
            "chromewebstore.google.com", "microsoftedge.microsoft.com",
            "addons.mozilla.org", "addons.opera.com", "workspace.google.com",
        }
        def _is_safe_ext_url(u: str) -> bool:
            if not validate_url(u):
                return False
            host = urlparse(u).netloc.lower().lstrip("www.")
            return any(host == h or host.endswith("." + h) for h in _ALLOWED_EXT_HOSTS)

        if not _is_safe_ext_url(url):
            _q_msg(self, tr("Invalid Extension URL"),
                tr("Extension URLs must use https:// and come from a recognised extension store "
                  "(Chrome Web Store, Firefox Add-ons, Edge Add-ons, Opera Add-ons, or "
                  "Google Workspace Marketplace)."),
                [(tr("OK"), "default")])
            return

        installed_exts = load_installed_extensions(app)
        installed_exts.append({"name": name, "web_url": url})
        save_installed_extensions(app, installed_exts)
        self.populate_extensions(app)
        browser_key = self._get_current_browser_key()
        profile_dir = get_profile_dir(app)
        _open_url_in_pwa_browser(browser_key, profile_dir, url, app)
        self.status_push(f"Added custom extension: {name} (via {browser_key.title()})")

    # ── Backup ────────────────────────────────────────────────────────────────

    def _confirm_backup_with_ext_check(self, app: dict, proceed_callback):
        exts = load_installed_extensions(app)
        if not exts:
            proceed_callback()
            return
        ext_names = "\n".join(f"  • {e.get('name','Unknown')}" for e in exts)
        resp = _q_msg(self,
            tr("Extensions Detected — Back Up Anyway?"),
            tr("%(name)s has %(count)d extension(s) recorded:\n\n%(list)s\n\n"
              "Browser extension files inside the profile directory can cause "
              "the backup to freeze or produce an inconsistent archive.\n\n"
              "For a clean backup, remove the extensions from the browser "
              "profile first, take the backup, then reinstall them afterward.\n\n"
              "You can still back up now — it may work — but it is not guaranteed to be stable.")
            % {"name": app.get("name","This app"), "count": len(exts), "list": ext_names},
            [(tr("Cancel"), "cancel"), (tr("Back Up Anyway"), "suggested")])
        if resp == tr("Back Up Anyway"):
            proceed_callback()

    def on_backup_profile(self):
        app = self.get_selected_app()
        if not app:
            return
        self._confirm_backup_with_ext_check(
            app, lambda: backup_profile(app, self.status_push))

    def on_open_backup_manager(self, *_args):
        app = self.get_selected_app()
        if not app:
            _q_msg(self, tr("Backup Manager"),
                   tr("Select an app in the main window first, then click Backup Manager."),
                   [(tr("OK"), "default")])
            return
        self._show_backup_manager_for_app(app)

    def _show_backup_manager_for_app(self, app: dict):
        dlg = QDialog(self)
        dlg.setWindowTitle(tr("Backup Manager — %(name)s") % {"name": app["name"]})
        dlg.setMinimumSize(560, 440)
        layout = QVBoxLayout(dlg)
        layout.setSpacing(8)
        layout.setContentsMargins(16, 16, 16, 16)

        layout.addWidget(QLabel(tr("<b>Backup Manager</b> — ") +
                                f"~/.appify/.backup/{slugify(app['name'])}/",
                                textFormat=Qt.TextFormat.RichText))

        create_btn = QPushButton("⬇  Create Backup Now")
        create_btn.setProperty("class", "suggested")
        create_btn.style().unpolish(create_btn)
        create_btn.style().polish(create_btn)
        layout.addWidget(create_btn)

        layout.addWidget(QLabel("<b>Existing Backups</b>",
                                textFormat=Qt.TextFormat.RichText))

        backup_list = QListWidget()
        backup_list.setMinimumHeight(200)
        backup_list.setAlternatingRowColors(True)
        layout.addWidget(backup_list)

        act_row = QHBoxLayout()
        restore_btn = QPushButton("↩  Restore Selected")
        delete_btn  = QPushButton("🗑  Delete Selected")
        delete_btn.setProperty("class", "destructive")
        delete_btn.style().unpolish(delete_btn)
        delete_btn.style().polish(delete_btn)
        act_row.addWidget(restore_btn)
        act_row.addWidget(delete_btn)
        layout.addLayout(act_row)

        close_btn = QPushButton("Close")
        close_btn.clicked.connect(dlg.accept)
        layout.addWidget(close_btn)

        def _populate():
            backup_list.clear()
            backups = list_backups(app)
            if not backups:
                item = QListWidgetItem(tr("No backups yet."))
                item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsSelectable)
                backup_list.addItem(item)
                restore_btn.setEnabled(False)
                delete_btn.setEnabled(False)
            else:
                restore_btn.setEnabled(True)
                delete_btn.setEnabled(True)
                for b in backups:
                    ts_str = datetime.datetime.fromtimestamp(b["mtime"]).strftime("%Y-%m-%d %H:%M")
                    item = QListWidgetItem(f"{ts_str}  •  {b['size_mb']} MB  •  {b['name']}")
                    item.setData(Qt.ItemDataRole.UserRole, b)
                    backup_list.addItem(item)

        _populate()

        def _on_create():
            def _do_backup():
                result = backup_profile(app)
                if result:
                    _populate()
                    self.status_push(f"Backup saved: {result.name}")
                else:
                    self.status_push("Backup failed — check logs")
            self._confirm_backup_with_ext_check(app, _do_backup)

        def _on_restore():
            item = backup_list.currentItem()
            if not item:
                return
            b = item.data(Qt.ItemDataRole.UserRole)
            if not b:
                return
            resp = _q_msg(dlg, tr("Restore Profile?"),
                tr("This will overwrite the current profile for %(name)s\n"
                  "with the backup from %(ts)s.\n\n"
                  "This cannot be undone (consider creating a backup first).") % {
                    "name": app["name"],
                    "ts": datetime.datetime.fromtimestamp(b["mtime"]).strftime("%Y-%m-%d %H:%M")},
                [(tr("Cancel"), "cancel"), (tr("Restore"), "suggested")])
            if resp == tr("Restore"):
                restore_profile(b["path"], app, self.status_push)
                _populate()

        def _on_delete():
            item = backup_list.currentItem()
            if not item:
                return
            b = item.data(Qt.ItemDataRole.UserRole)
            if not b:
                return
            resp = _q_msg(dlg, tr("Delete Backup?"),
                tr("Permanently delete %(name)s?") % {"name": b["name"]},
                [(tr("Cancel"), "cancel"), (tr("Delete"), "destructive")])
            if resp == tr("Delete"):
                delete_backup(b["path"], self.status_push)
                _populate()

        create_btn.clicked.connect(_on_create)
        restore_btn.clicked.connect(_on_restore)
        delete_btn.clicked.connect(_on_delete)
        dlg.exec()

    # ── Bulk operations ──────────────────────────────────────────────────────

    def on_backup_all(self, *_args):
        installed_slugs = list_installed_apps()
        if not installed_slugs:
            _q_msg(self, tr("Backup All Installed Apps"),
                   tr("No installed apps found."), [(tr("OK"), "default")])
            return
        apps_to_backup = [a for a in CONFIG["apps"].values()
                           if slugify(a["name"]) in installed_slugs]
        resp = _q_msg(self, tr("Backup All Installed Apps?"),
            tr("This will create a fresh backup for all %(count)d installed app(s).") % {
                "count": len(apps_to_backup)},
            [(tr("Cancel"), "cancel"), (tr("Backup All"), "suggested")])
        if resp != tr("Backup All"):
            return
        self.status_push(tr("Backing up %(count)d app(s)…") % {"count": len(apps_to_backup)})
        def _worker():
            ok_count = 0
            for a in apps_to_backup:
                result = backup_profile(a)
                if result:
                    ok_count += 1
                GLib.idle_add(self.status_push,
                    tr("Backed up %(name)s") % {"name": a["name"]})
            GLib.idle_add(self.status_push,
                tr("Backup complete: %(ok)d/%(total)d succeeded") % {
                    "ok": ok_count, "total": len(apps_to_backup)})
        threading.Thread(target=_worker, daemon=True).start()

    def on_install_all_in_category(self, *_args):
        dlg = QDialog(self)
        dlg.setWindowTitle(tr("Install All in Category"))
        dlg.setMinimumWidth(360)
        layout = QVBoxLayout(dlg)
        layout.addWidget(QLabel(tr("Install every catalog app in a category "
                                    "that isn't already installed:")))
        cat_combo = QComboBox()
        for cat in CATEGORIES:
            cat_combo.addItem(cat)
        layout.addWidget(cat_combo)
        btn_row = QHBoxLayout()
        cancel_btn = QPushButton(tr("Cancel"))
        install_btn = QPushButton(tr("Install All"))
        install_btn.setProperty("class", "suggested")
        install_btn.style().unpolish(install_btn)
        install_btn.style().polish(install_btn)
        cancel_btn.clicked.connect(dlg.reject)
        btn_row.addWidget(cancel_btn)
        btn_row.addWidget(install_btn)
        layout.addLayout(btn_row)

        def _do_install():
            category = cat_combo.currentText()
            dlg.accept()
            installed_slugs = set(list_installed_apps())
            targets = [a for a in CONFIG["apps"].values()
                       if a.get("category", "") == category
                       and slugify(a["name"]) not in installed_slugs]
            if not targets:
                self.status_push(
                    tr("Every app in %(cat)s is already installed.") % {"cat": category})
                return
            self.status_push(
                tr("Installing %(count)d app(s) in %(cat)s…") % {
                    "count": len(targets), "cat": category})
            def _worker():
                default_browser = CONFIG.get("browser", "firefox")
                gpu_default = CONFIG.get("gpu", True)
                nice_default = CONFIG.get("nice", 0)
                ionice_default = CONFIG.get("ionice", 2)
                ok_count = 0
                for a in targets:
                    browser_key = get_effective_browser(a, default_browser)
                    try:
                        install_app(a, browser_key, a.get("kiosk", False),
                                    nice_default, ionice_default, gpu_default,
                                    lambda msg: GLib.idle_add(self.status_push, msg))
                        ok_count += 1
                    except Exception as exc:
                        GLib.idle_add(self.status_push,
                            tr("Failed to install %(name)s: %(err)s") % {
                                "name": a["name"], "err": exc})
                GLib.idle_add(self.status_push,
                    tr("Category install complete: %(ok)d/%(total)d succeeded") % {
                        "ok": ok_count, "total": len(targets)})
                GLib.idle_add(self.populate_app_combo)
                GLib.idle_add(self.update_button_states)
            threading.Thread(target=_worker, daemon=True).start()

        install_btn.clicked.connect(_do_install)
        dlg.exec()

    # ── Self-Update ──────────────────────────────────────────────────────────

    def on_open_update_settings(self, *_args):
        dlg = QDialog(self)
        dlg.setWindowTitle(tr("Update Settings"))
        dlg.setMinimumWidth(480)
        layout = QVBoxLayout(dlg)
        layout.setSpacing(12)
        layout.setContentsMargins(16, 16, 16, 16)

        install_type, appimage_path = _detect_appify_install_type()
        install_desc = {
            "appimage": tr("AppImage (%(path)s)") % {"path": appimage_path},
            "deb":      tr("Debian package (.deb)"),
            "unknown":  tr("Unknown — not detected as a deb or AppImage install"),
        }[install_type]

        info_lbl = QLabel(
            f"<b>{tr('Installed version')}:</b> {CURRENT_VERSION}<br>"
            f"<b>{tr('Install type')}:</b> {install_desc}")
        info_lbl.setTextFormat(Qt.TextFormat.RichText)
        info_lbl.setWordWrap(True)
        layout.addWidget(info_lbl)

        latest_lbl = QLabel(tr("Latest version: checking…"))
        latest_lbl.setProperty("class", "caption")
        layout.addWidget(latest_lbl)

        check_row = QHBoxLayout()
        check_btn = QPushButton(tr("Check Now"))
        releases_btn = QPushButton(tr("Open GitHub Releases"))
        check_row.addWidget(check_btn)
        check_row.addWidget(releases_btn)
        layout.addLayout(check_row)

        install_update_btn = QPushButton(tr("Download && Install Update"))
        install_update_btn.setProperty("class", "suggested")
        install_update_btn.style().unpolish(install_update_btn)
        install_update_btn.style().polish(install_update_btn)
        install_update_btn.setEnabled(False)
        layout.addWidget(install_update_btn)

        sep = QFrame()
        sep.setFrameShape(QFrame.Shape.HLine)
        layout.addWidget(sep)

        sched_grp = QGroupBox(tr("Automatic Update Checks"))
        sched_layout = QVBoxLayout(sched_grp)

        installed_now = is_appify_updater_installed()
        current_schedule = get_appify_updater_schedule() or "*-*-* 04:00:00"
        status_lbl = QLabel(
            tr("Status: Enabled (checking on schedule below)") if installed_now
            else tr("Status: Not installed"))
        sched_layout.addWidget(status_lbl)

        freq_row = QHBoxLayout()
        freq_row.addWidget(QLabel(tr("Frequency:")))
        freq_combo = QComboBox()
        freq_combo.addItems([tr("Hourly"), tr("Daily"), tr("Weekly"), tr("Custom…")])
        freq_row.addWidget(freq_combo, 1)
        sched_layout.addLayout(freq_row)

        time_row = QHBoxLayout()
        time_row.addWidget(QLabel(tr("At:")))
        time_edit = QTimeEdit()
        time_edit.setDisplayFormat("HH:mm")
        time_edit.setTime(QTime(4, 0))
        time_row.addWidget(time_edit)
        time_row.addStretch()
        sched_layout.addLayout(time_row)

        custom_entry = QLineEdit()
        custom_entry.setPlaceholderText("*-*-* 04:00:00")
        custom_entry.setToolTip(
            "Raw systemd OnCalendar expression, e.g. *-*-* 04:00:00 or Mon,Fri 09:00")
        sched_layout.addWidget(custom_entry)

        m = re.match(r"^\*-\*-\* (\d{2}):(\d{2}):00$", current_schedule)
        if current_schedule == "hourly":
            freq_combo.setCurrentIndex(0)
        elif current_schedule == "weekly":
            freq_combo.setCurrentIndex(2)
        elif m:
            freq_combo.setCurrentIndex(1)
            time_edit.setTime(QTime(int(m.group(1)), int(m.group(2))))
        else:
            freq_combo.setCurrentIndex(3)
            custom_entry.setText(current_schedule)

        def _update_row_visibility():
            idx = freq_combo.currentIndex()
            time_edit.setVisible(idx == 1)
            custom_entry.setVisible(idx == 3)
        freq_combo.currentIndexChanged.connect(lambda _i: _update_row_visibility())
        _update_row_visibility()

        sched_btn_row = QHBoxLayout()
        apply_btn = QPushButton(tr("Enable / Apply Schedule"))
        apply_btn.setProperty("class", "suggested")
        apply_btn.style().unpolish(apply_btn)
        apply_btn.style().polish(apply_btn)
        disable_btn = QPushButton(tr("Disable"))
        disable_btn.setProperty("class", "destructive")
        disable_btn.style().unpolish(disable_btn)
        disable_btn.style().polish(disable_btn)
        disable_btn.setEnabled(installed_now)
        sched_btn_row.addWidget(apply_btn)
        sched_btn_row.addWidget(disable_btn)
        sched_layout.addLayout(sched_btn_row)

        layout.addWidget(sched_grp)

        close_btn = QPushButton(tr("Close"))
        close_btn.clicked.connect(dlg.accept)
        layout.addWidget(close_btn)

        _state = {"release": None}

        def _resolve_schedule() -> str:
            idx = freq_combo.currentIndex()
            if idx == 0:
                return "hourly"
            elif idx == 1:
                t = time_edit.time()
                return f"*-*-* {t.hour():02d}:{t.minute():02d}:00"
            elif idx == 2:
                return "weekly"
            else:
                return custom_entry.text().strip() or "*-*-* 04:00:00"

        def _do_check():
            check_btn.setEnabled(False)
            latest_lbl.setText(tr("Latest version: checking…"))
            def _worker():
                release = check_appify_latest_release()
                def _apply():
                    check_btn.setEnabled(True)
                    if not release:
                        latest_lbl.setText(
                            tr("Latest version: could not check (no network / rate limited)"))
                        return
                    _state["release"] = release
                    try:
                        is_newer = Version(release["version"]) > Version(CURRENT_VERSION)
                    except Exception:
                        is_newer = release["version"] != CURRENT_VERSION
                    suffix = tr("(update available)") if is_newer else tr("(up to date)")
                    latest_lbl.setText(
                        tr("Latest version: %(v)s %(suffix)s") % {
                            "v": release["version"], "suffix": suffix})
                    install_update_btn.setEnabled(is_newer and install_type != "unknown")
                GLib.idle_add(_apply)
            threading.Thread(target=_worker, daemon=True).start()

        def _open_releases():
            release = _state["release"]
            url = release["html_url"] if release else f"https://github.com/{APPIFY_GITHUB_REPO}/releases"
            subprocess.Popen(["xdg-open", url])

        def _do_install_update():
            release = _state["release"]
            if not release:
                return
            resp = _q_msg(dlg, tr("Install Update?"),
                tr("Download and install Appify %(v)s now?\n\n"
                   "Appify will need to be restarted afterwards to use the new version.") % {
                       "v": release["version"]},
                [(tr("Cancel"), "cancel"), (tr("Install"), "suggested")])
            if resp != tr("Install"):
                return
            install_update_btn.setEnabled(False)
            self.status_push(tr("Updating Appify…"))
            def _worker():
                ok = install_appify_update(release, lambda msg: GLib.idle_add(self.status_push, msg))
                GLib.idle_add(install_update_btn.setEnabled, not ok)
            threading.Thread(target=_worker, daemon=True).start()

        def _do_apply_schedule():
            schedule = _resolve_schedule()
            apply_btn.setEnabled(False)
            self.status_push(tr("Applying update schedule…"))
            def _worker():
                if is_appify_updater_installed():
                    set_appify_updater_schedule(schedule, lambda msg: GLib.idle_add(self.status_push, msg))
                else:
                    enable_appify_updater(schedule, lambda msg: GLib.idle_add(self.status_push, msg))
                def _apply():
                    apply_btn.setEnabled(True)
                    now_installed = is_appify_updater_installed()
                    disable_btn.setEnabled(now_installed)
                    status_lbl.setText(
                        tr("Status: Enabled (checking on schedule below)") if now_installed
                        else tr("Status: Not installed"))
                GLib.idle_add(_apply)
            threading.Thread(target=_worker, daemon=True).start()

        def _do_disable():
            resp = _q_msg(dlg, tr("Disable Automatic Update Checks?"),
                tr("Appify will no longer check for updates on a schedule. "
                   "You can still check manually above."),
                [(tr("Cancel"), "cancel"), (tr("Disable"), "destructive")])
            if resp != tr("Disable"):
                return
            disable_btn.setEnabled(False)
            def _worker():
                disable_appify_updater(lambda msg: GLib.idle_add(self.status_push, msg))
                GLib.idle_add(status_lbl.setText, tr("Status: Not installed"))
            threading.Thread(target=_worker, daemon=True).start()

        check_btn.clicked.connect(_do_check)
        releases_btn.clicked.connect(_open_releases)
        install_update_btn.clicked.connect(_do_install_update)
        apply_btn.clicked.connect(_do_apply_schedule)
        disable_btn.clicked.connect(_do_disable)

        _do_check()
        dlg.exec()

    # ── Clone ─────────────────────────────────────────────────────────────────

    def on_clone(self):
        app = self.get_selected_app()
        if not app:
            return
        dlg = QDialog(self)
        dlg.setWindowTitle(f"Clone {app['name']}")
        dlg.setMinimumWidth(380)
        layout = QVBoxLayout(dlg)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(8)
        layout.addWidget(QLabel("New App Name"))
        name_entry = QLineEdit()
        name_entry.setText(f"{app['name']} (Clone)")
        layout.addWidget(name_entry)
        btn_row = QHBoxLayout()
        btn_row.addStretch()
        cancel_b = QPushButton("Cancel")
        cancel_b.clicked.connect(dlg.reject)
        clone_b = QPushButton("Clone")
        clone_b.setProperty("class", "suggested")
        clone_b.style().unpolish(clone_b)
        clone_b.style().polish(clone_b)
        clone_b.clicked.connect(dlg.accept)
        btn_row.addWidget(cancel_b)
        btn_row.addWidget(clone_b)
        layout.addLayout(btn_row)

        if dlg.exec() != QDialog.DialogCode.Accepted:
            return

        new_name = name_entry.text().strip()
        if not new_name:
            return
        new_slug = slugify(new_name)
        if new_slug in CONFIG["apps"]:
            _q_msg(self, tr("Name Already Exists"),
                tr("An app named %(name)r already exists (or maps to the same identifier). "
                  "Please choose a different name.") % {"name": new_name},
                [(tr("OK"), "default")])
            return
        new_app = app.copy()
        new_app["name"] = new_name
        CONFIG["apps"][new_slug] = new_app
        save_config()
        self.populate_app_combo()
        new_index = next((i for i, a in enumerate(self.sorted_apps_list) if a["name"] == new_name), 0)
        self.app_combo.setCurrentIndex(new_index)
        self.status_push(f"Cloned to {new_name}")


# ─────────────────────────────────────────────────────────────────────────────
# main()
# ─────────────────────────────────────────────────────────────────────────────

def main():
    global _idle_dispatcher

    parser = argparse.ArgumentParser()
    parser.add_argument("--launch-app", type=str)
    parser.add_argument("--print-version", action="store_true",
                         help="Print the installed Appify version and exit (used by appify-updater.sh).")
    args = parser.parse_args()
    if args.print_version:
        print(CURRENT_VERSION)
        return
    if args.launch_app:
        launch_app_from_cli(args.launch_app)
        return

    app = QApplication(sys.argv)
    app.setApplicationName("Appify")
    app.setApplicationVersion(CURRENT_VERSION)
    app.setOrganizationName("BobbyComet")

    # Create thread-safe idle dispatcher after QApplication exists
    _idle_dispatcher = _QtIdleDispatcher()

    # Apply Griffin dark theme (or light if saved preference)
    dark = CONFIG.get("dark_mode", True)
    app.setStyleSheet(GRIFFIN_DARK_QSS if dark else GRIFFIN_LIGHT_QSS)

    win = PWAManagerWindow()
    win.show()

    sys.exit(app.exec())


if __name__ == "__main__":
    script_path = Path(__file__)
    if not os.access(script_path, os.X_OK):
        try:
            script_path.chmod(0o755)
        except OSError:
            pass
    main()
