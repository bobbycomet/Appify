        # Re-polish all buttons with custom class to pick up QSS
        for btn in [self.install_btn, self.install_custom_btn, self.uninstall_btn,
                    self.remove_btn, self.launch_btn]:
            btn.style().unpolish(btn)
            btn.style().polish(btn)

    def _build_status_bar(self):
        self.statusBar().showMessage("")

    def _post_init(self):
        if self.sorted_apps_list:
            self.app_combo.setCurrentIndex(0)
            self.populate_app_fields(self.sorted_apps_list[0])
        self.update_button_states()

        try:
            _stale_fixed = cleanup_stale_pwa_desktop_files(self.status_push)
            if _stale_fixed:
                self.status_push(
                    tr("Fixed %(n)d stale shortcut(s)") % {"n": _stale_fixed})
        except Exception as _exc:
            _logger.warning("Stale shortcut cleanup failed: %s", _exc)

        if _WRAPPER_REGEN_NEEDED:
            try:
                _n = regenerate_all_wrappers(self.status_push)
                self.status_push(
                    tr("Fixed a stale Firefox launch setting and regenerated "
                       "%(n)d wrapper(s)") % {"n": _n})
                _q_msg(self, tr("Firefox launch settings repaired"),
                    tr("An old Firefox launch setting (--user-data-dir) was "
                       "found in your config — Firefox never understood that "
                       "flag, so custom profiles, prefs, and any "
                       "userChrome.css/userContent.css never actually "
                       "applied. This has been corrected and all installed "
                       "wrappers were regenerated automatically."),
                    [(tr("OK"), "default")])
            except Exception as _exc:
                _logger.warning("Post-migration wrapper regen failed: %s", _exc)

        if _MIGRATION_NEEDED:
            QTimer.singleShot(200, self._show_migration_dialog)

        GLib.timeout_add_seconds(2, lambda: (check_for_updates(self._show_update_banner) or False))

        # Load the store catalog in the background so the UI stays responsive
        threading.Thread(target=self._bg_load_catalog, daemon=True).start()

    def _bg_load_catalog(self):
        """Background worker: load store catalog then refresh the app list."""
        _load_store_catalog(
            status_callback=lambda msg: GLib.idle_add(self.status_push, msg))
        GLib.idle_add(self._on_catalog_loaded)

    def _on_catalog_loaded(self):
        """Called on the main thread after the catalog has been applied."""
        current_search = self.search_entry.text().strip()
        self.populate_app_combo(current_search)
        self.update_button_states()
        # Refresh the category browser with the now-full category list
        self.cat_combo.blockSignals(True)
        current_cat_text = self.cat_combo.currentText()
        self.cat_combo.clear()
        for cat in CATEGORIES:
            self.cat_combo.addItem(cat)
        idx = self.cat_combo.findText(current_cat_text)
        self.cat_combo.setCurrentIndex(max(idx, 0))
        self.cat_combo.blockSignals(False)
        self._populate_category_list(self.cat_combo.currentText())

    def on_refresh_catalog(self, *_args):
        """Force-refresh the store catalog from GitHub."""
        self.status_push("Refreshing catalog from GitHub…")
        def _worker():
            data = _fetch_store_from_network()
            if data:
                _apply_store_catalog(data)
                GLib.idle_add(self._on_catalog_loaded)
                GLib.idle_add(self.status_push,
                              f"Catalog refreshed: {len(data.get('apps',[]))} apps")
            else:
                GLib.idle_add(self.status_push, "Catalog refresh failed — check network")
        threading.Thread(target=_worker, daemon=True).start()

    # ── Thread-safe status / profile size ────────────────────────────────────

    def status_push(self, msg: str):
        self._status_sig.emit(msg)

    def _do_status_push(self, msg: str):
        self.statusBar().showMessage(msg)
        if self._status_timer:
            self._status_timer.stop()
        self._status_timer = QTimer()
        self._status_timer.setSingleShot(True)
        self._status_timer.timeout.connect(lambda: self.statusBar().showMessage(""))
        self._status_timer.start(5000)

    def _on_profile_size_ready(self, size_str: str):
        self.profile_size_label.setText(size_str)

    def _update_profile_size_label(self, app: "dict | None"):
        if app is None:
            self.profile_size_label.setText("—")
            return
        sig = self._prof_size_sig
        def _measure():
            size_str = get_profile_size(app)
            sig.emit(size_str)
        threading.Thread(target=_measure, daemon=True).start()

    # ── Update banner ─────────────────────────────────────────────────────────

    def _show_update_banner(self, msg: str):
        if not msg:
            return
        version_line = msg.split("\n")[0]
        self._update_banner.set_title(version_line)
        self._update_banner.set_revealed(True)
        self.status_push(tr("Update available!"))

    # ── Dark mode ─────────────────────────────────────────────────────────────

    def on_mode_toggled(self, checked: bool):
        CONFIG["dark_mode"] = checked
        save_config()
        QApplication.instance().setStyleSheet(GRIFFIN_DARK_QSS if checked else GRIFFIN_LIGHT_QSS)
        self.status_push(f"Switched to {'Dark' if checked else 'Light'} mode")

    # ── Migration ─────────────────────────────────────────────────────────────

    def _show_migration_dialog(self):
        self.on_migrate_dir()

    def on_migrate_dir(self, *_args):
        if not _OLD_CONFIG_DIR.exists():
            _q_msg(self, tr("Already Using .appify"),
                   tr("Your Appify data directory is already ~/.appify.\nNo migration is needed."),
                   [(tr("OK"), "default")])
            return

        resp = _q_msg(self,
            tr("Migrate Data Directory to .appify?"),
            tr("Appify now stores its data in ~/.appify instead of ~/.pwa_manager.\n\n"
              "Migrating will rename ~/.pwa_manager to ~/.appify. All your apps, "
              "profiles, scripts, backups, and settings will be preserved exactly "
              "as they are — nothing is deleted.\n\n"
              "After migration, browser extensions inside your app profiles may "
              "appear as disabled or corrupted. This is a browser limitation, not "
              "an Appify bug. To fix it, open each app's browser, go to the "
              "extension manager, and click Repair on any extension that needs it.\n\n"
              "You can migrate now or come back to this option later from the menu."),
            [(tr("Later"), "cancel"), (tr("Migrate Now"), "suggested")])
        if resp != tr("Migrate Now"):
            return
        self._do_migrate()

    def _do_migrate(self):
        global CONFIG_DIR, CONFIG_FILE, LOG_FILE, BACKUP_DIR
        try:
            _OLD_CONFIG_DIR.rename(Path(os.path.expanduser("~/.appify")))
            CONFIG_DIR  = Path(os.path.expanduser("~/.appify"))
            CONFIG_FILE = CONFIG_DIR / "config.json"
            LOG_FILE    = CONFIG_DIR / "launch.log"
            BACKUP_DIR  = CONFIG_DIR / ".backup"
            _logger.info("Migrated config directory → %s", CONFIG_DIR)
        except Exception as exc:
            _logger.error("Migration failed: %s", exc)
            _q_msg(self, tr("Migration Failed"),
                   tr("Could not rename ~/.pwa_manager to ~/.appify:\n%(err)s\n\n"
                     "Your data is unchanged.") % {"err": exc},
                   [(tr("OK"), "default")])
            return

        _q_msg(self, tr("Migration Complete"),
               tr("Your data has been moved to ~/.appify successfully.\n\n"
                 "If any browser extensions appear disabled, open that app's browser, "
                 "navigate to the extension manager, and click Repair on any extension.\n\n"
                 "Ad blockers are the most commonly affected."),
               [(tr("OK"), "default")])
        self.status_push(tr("Migrated to ~/.appify ✓ (restart recommended)"))
        try:
            regenerate_all_wrappers(self.status_push)
        except Exception as _exc:
            _logger.warning("Post-migration wrapper regeneration failed: %s", _exc)

    # ── Category browser ──────────────────────────────────────────────────────

    def _populate_category_list(self, category: str):
        self.cat_list.clear()
        installed: set[str] = set(list_installed_apps())
        category_apps = sorted(
            [a for a in CONFIG["apps"].values() if a.get("category", "") == category],
            key=lambda a: a["name"].lower())

        if not category_apps:
            item = QListWidgetItem(tr("No apps in this category."))
            item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsSelectable)
            self.cat_list.addItem(item)
            return

        for app in category_apps:
            slug = slugify(app["name"])
            marker = "✓ " if slug in installed else "    "
            item = QListWidgetItem(f"{marker}{app['name']}")
            item.setData(Qt.ItemDataRole.UserRole, app)
            self.cat_list.addItem(item)

        # Connect double-click to select
        try:
            self.cat_list.itemDoubleClicked.disconnect()
        except Exception:
            pass
        self.cat_list.itemDoubleClicked.connect(self._on_category_item_double_clicked)

        # "Select" button row below list
        try:
            self.cat_list.itemClicked.disconnect()
        except Exception:
            pass
        self.cat_list.itemClicked.connect(lambda item: (
            self._on_category_select_app(item.data(Qt.ItemDataRole.UserRole))
            if item.data(Qt.ItemDataRole.UserRole) else None
        ))

    def _on_category_item_double_clicked(self, item: QListWidgetItem):
        app = item.data(Qt.ItemDataRole.UserRole)
        if app:
            self._on_category_select_app(app)

    def on_category_selected(self, idx: int):
        if 0 <= idx < len(CATEGORIES):
            self._populate_category_list(CATEGORIES[idx])

    def _on_category_select_app(self, app: dict):
        if not app:
            return
        target_name = app.get("name", "")
        current_search = self.search_entry.text().strip()
        if current_search:
            if not any(a.get("name") == target_name for a in self.sorted_apps_list):
                self.search_entry.setText("")
                self.populate_app_combo()
        new_idx = next(
            (i for i, a in enumerate(self.sorted_apps_list) if a.get("name") == target_name),
            None)
        if new_idx is not None:
            self.app_combo.setCurrentIndex(new_idx)
            self.populate_app_fields(self.sorted_apps_list[new_idx])
            self.populate_extensions(self.sorted_apps_list[new_idx])
            self.update_button_states()
            self.status_push(tr("Selected: %(name)s") % {"name": target_name})

    # ── Wrapper regeneration ──────────────────────────────────────────────────

    def on_regenerate_wrappers(self, *_args):
        session = (CONFIG.get("session_type") or "unknown").upper()
        compositor = CONFIG.get("wayland_compositor", "n/a")
        session_desc = (f"{session} / {compositor.title()}"
                        if is_wayland_session() and compositor not in ("n/a", "unknown")
                        else session)
        resp = _q_msg(self, tr("Regenerate All Wrappers?"),
            tr("This will rewrite the launcher script and desktop file for every "
              "installed app using the current display session settings.\n\n"
              f"Current session: {session_desc}\n\n"
              "Use this after switching between X11 and Wayland, or after "
              "changing how a browser is installed (native ↔ Flatpak ↔ Snap).\n\n"
              "No profile data will be modified."),
            [(tr("Cancel"), "cancel"), (tr("Regenerate"), "suggested")])
        if resp != tr("Regenerate"):
            return
        self.status_push(tr("Regenerating wrappers…"))
        def _worker():
            count = regenerate_all_wrappers()
            GLib.idle_add(self.status_push,
                tr("Regenerated %(count)d wrapper(s) for %(session)s") % {
                    "count": count, "session": session_desc})
            GLib.idle_add(self.populate_app_combo)
            GLib.idle_add(self.update_button_states)
        threading.Thread(target=_worker, daemon=True).start()

    # ── Export / Import ───────────────────────────────────────────────────────

    def on_export_data(self, *_args):
        resp = _q_msg(self, tr("Extensions Cannot Be Exported"),
            tr("Extensions cannot be exported due to browser limitations. "
              "It is recommended to uninstall them before continuing.\n\n"
              "You will need to reinstall them on the destination machine.\n\nProceed?"),
            [(tr("No"), "cancel"), (tr("Yes, Export"), "suggested")])
        if resp != tr("Yes, Export"):
            return
        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        default_name = f"appify_export_{ts}.zip"
        dest_str, _filter = QFileDialog.getSaveFileName(
            self, tr("Export All Appify Data"),
            str(Path.home() / default_name),
            tr("Zip archives (*.zip)"))
        if not dest_str:
            return
        dest = Path(dest_str)
        if dest.suffix.lower() != ".zip":
            dest = dest.with_suffix(".zip")
        self.status_push(tr("Exporting data…"))
        def _worker():
            ok = export_all_data(dest, lambda msg: GLib.idle_add(self.status_push, msg))
            if ok:
                GLib.idle_add(self.status_push,
                              tr("Export saved to: %(path)s") % {"path": dest})
            else:
                GLib.idle_add(self.status_push, tr("Export failed — check logs"))
        threading.Thread(target=_worker, daemon=True).start()

    def on_import_data(self, *_args):
        resp = _q_msg(self, tr("Import Appify Data?"),
            tr("Importing will replace your entire Appify data directory with the "
              "contents of the selected zip file.\n\n"
              "Your current data will be backed up automatically to a timestamped "
              "folder in your home directory before anything is overwritten.\n\n"
              "After import, all launcher scripts will be regenerated for this machine.\n\n"
              "Only import zip files created by Appify's own Export function."),
            [(tr("Cancel"), "cancel"), (tr("Choose File…"), "suggested")])
        if resp != tr("Choose File…"):
            return
        zip_str, _filter = QFileDialog.getOpenFileName(
            self, tr("Select Appify Export File"),
            str(Path.home()),
            tr("Zip archives (*.zip)"))
        if not zip_str:
            return
        zip_path = Path(zip_str)
        self.status_push(tr("Importing data…"))
        def _worker():
            ok = import_all_data(zip_path, lambda msg: GLib.idle_add(self.status_push, msg))
            if ok:
                GLib.idle_add(self._post_import_refresh)
            else:
                GLib.idle_add(self.status_push, tr("Import failed — check logs"))
        threading.Thread(target=_worker, daemon=True).start()

    def _post_import_refresh(self):
        CONFIG["session_type"]       = get_session_type()
        CONFIG["available_browsers"] = scan_available_browsers()
        CONFIG["browser"]            = get_default_browser()
        CONFIG["wayland_compositor"] = (
            detect_wayland_compositor() if is_wayland_session() else "n/a")
        save_config()
        self.refresh_browser_combo()
        self.populate_app_combo()
        self.update_button_states()
        self.status_push(
            tr("Import complete — %(n)d app(s) loaded") % {"n": len(CONFIG.get("apps", {}))})

