        self.uninstall_btn = QPushButton(tr("Uninstall"))
        self.uninstall_btn.setProperty("class", "destructive")
        self.uninstall_btn.clicked.connect(self.on_uninstall)

        self.clone_btn = QPushButton(tr("Clone App"))
        self.clone_btn.clicked.connect(self.on_clone)

